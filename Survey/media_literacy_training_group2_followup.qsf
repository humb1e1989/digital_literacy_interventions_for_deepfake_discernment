HlvOBspw","Element":"SQ","PrimaryAttribute":"QID203","SecondaryAttribute":" ","TertiaryAttribute":null,"Payload":{"QuestionText":"<img alt=\"Image\" src=\"${lm:\/\/Field\/1}\" \/><br \/>","DefaultChoices":false,"DataExportTag":"feedback_image","QuestionID":"QID203","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":" ","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionJS":"Qualtrics.SurveyEngine.addOnload(function()\n{\n\t\/*Place your JavaScript here to run when the page loads*\/\n\tvar imageUrl = \"${lm:\/\/Field\/1}\";\n\n    \/\/ Create a new Image object to preload the image\n    var img = new Image();\n\n    \/\/ Set the source to the image URL\n    img.src = imageUrl;\n\n});\n\nQualtrics.SurveyEngine.addOnReady(function()\n{\n\t\/*Place your JavaScript here to run when the page is fully displayed*\/\n\n});\n\nQualtrics.SurveyEngine.addOnUnload(function()\n{\n\t\/*Place your JavaScript here to run when the page is unloaded*\/\n\n});"}},{"SurveyID":"SV_cZsGe9lHlvOBspw","Element":"SQ","PrimaryAttribute":"QID204","SecondaryAttribute":"Timing","TertiaryAttribute":null,"Payload":{"QuestionText":"Timing","DefaultChoices":false,"DataExportTag":"feedback_intro_timer","QuestionType":"Timing","Selector":"PageTimer","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","MinSeconds":5,"MaxSeconds":"0"},"QuestionDescription":"Timing","Choices":{"1":{"Display":"First Click"},"2":{"Display":"Last Click"},"3":{"Display":"Page Submit"},"4":{"Display":"Click Count"}},"GradingData":[],"Language":[],"NextChoiceId":52,"NextAnswerId":1,"QuestionID":"QID204"}},{"SurveyID":"SV_cZsGe9lHlvOBspw","Element":"SQ","PrimaryAttribute":"QID205","SecondaryAttribute":"Training completed! \u00a0 Thank you for completing the training on how to detect fake images. You've...","TertiaryAttribute":null,"Payload":{"QuestionText":"<p><strong>Training completed!<\/strong><br \/>\n&nbsp;<\/p>\n\n<p>Thank you for completing the training on how to detect fake images.<\/p>\n\n<p>You&#39;ve now learned some key techniques for distinguishing between real images taken by humans and fake images created by AI.<\/p>\n\n<p>In the next section, you&#39;ll be asked to apply what you&#39;ve learned in the <strong>actual detection task<\/strong>. Your responses there will be part of our research data.<\/p>\n\n<p>Click &quot;Next&quot; when you&#39;re ready to continue.<\/p>","DefaultChoices":false,"DataExportTag":"feedback_end","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Training completed! \u00a0 Thank you for completing the training on how to detect fake images. You've...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID205"}},{"SurveyID":"SV_cZsGe9lHlvOBspw","Element":"SQ","PrimaryAttribute":"QID206","SecondaryAttribute":"Is this image\u00a0real\u00a0or\u00a0fake?*","TertiaryAttribute":null,"Payload":{"QuestionText":"<img src=\"https:\/\/lmubwl.eu.qualtrics.com\/CP\/Graphic.php?IM=IM_1H7b55l9RMBjXJI\" style=\"width: 532px; height: 297px;\" \/><br \/>\n<br \/>\nIs this image&nbsp;<strong>real&nbsp;<\/strong>or&nbsp;<strong>fake<\/strong>?<span style=\"color:#e74c3c;\">*<\/span>","QuestionJS":"Qualtrics.SurveyEngine.addOnload(function()\n{\n\t\/*Place your JavaScript here to run when the page loads*\/\n\t\/\/ Set up an array of correct answers\n    var correctAnswers = [\"3\", \"4\"]; \/\/ Change these to your two correct answer IDs\n\tvar answerSubmitted = false; \/\/ Track if an answer has been submitted\n\t\n\t\/\/ Add a CSS rule for shake animation\n    var style = document.createElement('style');\n    style.type = 'text\/css';\n    style.innerHTML = `\n    @keyframes shake {\n        0% { transform: translateX(0); }\n        10% { transform: translateX(-5px); }\n        20% { transform: translateX(5px); }\n        30% { transform: translateX(-5px); }\n        40% { transform: translateX(5px); }\n        50% { transform: translateX(-5px); }\n        60% { transform: translateX(5px); }\n        70% { transform: translateX(-5px); }\n        80% { transform: translateX(5px); }\n        90% { transform: translateX(-5px); }\n        100% { transform: translateX(0); }\n    }\n    .shake {\n        animation: shake 0.6s ease;\n    }`;\n    document.getElementsByTagName('head')[0].appendChild(style);\n    \n    \/\/ Create a div for feedback that will appear next to the image\n    var feedbackDiv = document.createElement(\"div\");\n    feedbackDiv.id = \"feedbackText\";\n    feedbackDiv.style.marginTop = \"10px\";\n    feedbackDiv.style.padding = \"10px\";\n    feedbackDiv.style.borderRadius = \"5px\";\n    feedbackDiv.style.display = \"none\"; \/\/ Initially hidden\n    \n    \/\/ Find the image container and add the feedback div after it\n    var imageElement = document.querySelector(\".QuestionText img\");\n    if (imageElement) {\n        imageElement.parentNode.insertBefore(feedbackDiv, imageElement.nextSibling);\n    }\n    \n    \/\/ When an answer is clicked\n    this.questionclick = function(event, element) {\n        if (element.type == \"radio\" && !answerSubmitted) {\n            \/\/ Set the flag to indicate an answer has been submitted\n            answerSubmitted = true;\n\t\t\t\n            \/\/ Get all the answer choices\n            var choices = document.getElementsByName(this.questionId);\n            \n            \/\/ Process the selection\n            var selectedChoice = element.parentElement;\n            \n            \/\/ Show the feedback div\n            feedbackDiv.style.display = \"block\";\n            \n            \/\/ Check if the selected answer is in our array of correct answers\n            if (correctAnswers.includes(element.value)) {\n                \/\/ Correct answer styling\n                selectedChoice.style.backgroundColor = \"#e6ffe6\"; \/\/ Light green\n                feedbackDiv.style.backgroundColor = \"#e6ffe6\"; \/\/ Light green\n                feedbackDiv.innerHTML = \"<strong>Correct!<\/strong> This is a <strong>REAL<\/strong> image.\";\n            } else {\n                \/\/ Incorrect answer styling\n                selectedChoice.style.backgroundColor = \"#ffe6e6\"; \/\/ Light red\n                feedbackDiv.style.backgroundColor = \"#ffe6e6\"; \/\/ Light red\n                feedbackDiv.innerHTML = \"<strong>Not quite.<\/strong> This is actually a <strong>REAL<\/strong> image.\";\n\t\t\t\t\/\/ Add shake animation to wrong answer\n                selectedChoice.classList.add(\"shake\");\n            }\n            \n            \/\/ Highlight all correct answers\n            for (var i = 0; i < choices.length; i++) {\n                if (correctAnswers.includes(choices[i].value)) {\n                    choices[i].parentElement.style.backgroundColor = \"#e6ffe6\"; \/\/ Light green\n                }\n            }\n            \n            \/\/ Disable all radio buttons to prevent further selection\n            for (var i = 0; i < choices.length; i++) {\n                choices[i].disabled = true;\n                \n                \/\/ Add visual indication that the option is disabled\n                if (!correctAnswers.includes(choices[i].value) && choices[i].value != element.value) {\n                    choices[i].parentElement.style.opacity = \"0.5\";\n                }\n            }\n            \n            \/\/ Add a note that the answer has been recorded\n            var noteDiv = document.createElement(\"div\");\n            noteDiv.innerHTML = \"<em>Your answer has been recorded. Please continue to the next question.<\/em>\";\n            noteDiv.style.marginTop = \"10px\";\n            noteDiv.style.fontStyle = \"italic\";\n            feedbackDiv.appendChild(noteDiv);\n        }\n    };\n\n\n});\n\nQualtrics.SurveyEngine.addOnReady(function()\n{\n\t\/*Place your JavaScript here to run when the page is fully displayed*\/\n\n});\n\nQualtrics.SurveyEngine.addOnUnload(function()\n{\n\t\/*Place your JavaScript here to run when the page is unloaded*\/\n\n});","DefaultChoices":false,"DataExportTag":"Q206","QuestionID":"QID206","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Is this image\u00a0real\u00a0or\u00a0fake?*","Choices":{"4":{"Display":"Definitely real"},"6":{"Display":"Probably real"},"7":{"Display":"Probably fake"},"8":{"Display":"Definitely fake"}},"ChoiceOrder":["4","6","7","8"],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":9,"NextAnswerId":1}},{"SurveyID":"SV_cZsGe9lHlvOBspw","Element":"SQ","PrimaryAttribute":"QID207","SecondaryAttribute":"Is this image real or fake?*","TertiaryAttribute":null,"Payload":{"QuestionText":"Is this image <strong>real <\/strong>or <strong>fake<\/strong>?<span style=\"color:#FF0000;\">*<\/span>","DefaultChoices":false,"QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Is this image real or fake?*","Choices":{"1":{"Display":"Definitely real"},"2":{"Display":"Probably real"},"3":{"Display":"Probably fake"},"4":{"Display":"Definitely fake"}},"ChoiceOrder":[1,2,3,4],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":5,"NextAnswerId":5,"QuestionJS":"Qualtrics.SurveyEngine.addOnload(function()\n{\n    var imageUrl = \"${lm:\/\/Field\/1}\";\n\n    \/\/ Create a new Image object to preload the image\n    var img = new Image();\n\n    \/\/ Set the source to the image URL\n    img.src = imageUrl;\n\t\/\/ Get the loop field value\n    var imageType = \"${lm:\/\/Field\/2}\";\n    \n    \/\/ Set it as embedded data\n    Qualtrics.SurveyEngine.setEmbeddedData('currentImageType', imageType);\n\n});\n\nQualtrics.SurveyEngine.addOnReady(function()\n{\n\t\/*Place your JavaScript here to run when the page is fully displayed*\/\n\n});\n\nQualtrics.SurveyEngine.addOnUnload(function()\n{\n\t\/*Place your JavaScript here to run when the page is unloaded*\/\n\n});","QuestionText_Unsafe":"Is this image <strong>real <\/strong>or <strong>fake<\/strong>?<span style=\"color:#FF0000;\">*<\/span>","DataExportTag":"Q207","QuestionID":"QID207"}},{"SurveyID":"SV_cZsGe9lHlvOBspw","Element":"SQ","PrimaryAttribute":"QID208","SecondaryAttribute":"Solution: The image was \u274cFAKE\u274c! Look closely to spot potential inconsistencies. Ready for the ne","TertiaryAttribute":null,"Payload":{"QuestionText":"<strong>Solution:<\/strong><br \/>\nThe image was <span style=\"font-size:19px;\">\u274c<\/span><span style=\"color:#e74c3c;\"><span style=\"font-size:19px;\"><strong>FAKE\u274c<\/strong><\/span><\/span>! Look closely to spot potential inconsistencies.<br \/>\n<br \/>\nReady for the next one?","DefaultChoices":false,"QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Solution: The image was \u274cFAKE\u274c! Look closely to spot potential inconsistencies. Ready for the nex...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionJS":false,"QuestionText_Unsafe":"Solution:<br \/>\nThe image was <span style=\"font-size:19px;\"><strong>${lm:\/\/Field\/2}<\/strong><\/span>!<br \/>\n<br \/>\nReady for the next one?\n","DataExportTag":"Q208","QuestionID":"QID208","InPageDisplayLog