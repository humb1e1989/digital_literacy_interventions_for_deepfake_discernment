 this.questionclick = function(event, element) {\n        if (element.type == \"radio\" && !answerSubmitted) {\n            \/\/ Set the flag to indicate an answer has been submitted\n            answerSubmitted = true;\n\t\t\t\n            \/\/ Get all the answer choices\n            var choices = document.getElementsByName(this.questionId);\n            \n            \/\/ Process the selection\n            var selectedChoice = element.parentElement;\n            \n            \/\/ Show the feedback div\n            feedbackDiv.style.display = \"block\";\n            \n            \/\/ Check if the selected answer is in our array of correct answers\n            if (correctAnswers.includes(element.value)) {\n                \/\/ Correct answer styling\n                selectedChoice.style.backgroundColor = \"#e6ffe6\"; \/\/ Light green\n                feedbackDiv.style.backgroundColor = \"#e6ffe6\"; \/\/ Light green\n                feedbackDiv.innerHTML = \"<strong>Correct!<\/strong> This is a <strong>REAL<\/strong> image.\";\n            } else {\n                \/\/ Incorrect answer styling\n                selectedChoice.style.backgroundColor = \"#ffe6e6\"; \/\/ Light red\n                feedbackDiv.style.backgroundColor = \"#ffe6e6\"; \/\/ Light red\n                feedbackDiv.innerHTML = \"<strong>Not quite.<\/strong> This is actually a <strong>REAL<\/strong> image.\";\n\t\t\t\t\/\/ Add shake animation to wrong answer\n                selectedChoice.classList.add(\"shake\");\n            }\n            \n            \/\/ Highlight all correct answers\n            for (var i = 0; i < choices.length; i++) {\n                if (correctAnswers.includes(choices[i].value)) {\n                    choices[i].parentElement.style.backgroundColor = \"#e6ffe6\"; \/\/ Light green\n                }\n            }\n            \n            \/\/ Disable all radio buttons to prevent further selection\n            for (var i = 0; i < choices.length; i++) {\n                choices[i].disabled = true;\n                \n                \/\/ Add visual indication that the option is disabled\n                if (!correctAnswers.includes(choices[i].value) && choices[i].value != element.value) {\n                    choices[i].parentElement.style.opacity = \"0.5\";\n                }\n            }\n            \n            \/\/ Add a note that the answer has been recorded\n            var noteDiv = document.createElement(\"div\");\n            noteDiv.innerHTML = \"<em>Your answer has been recorded. Please continue to the next question.<\/em>\";\n            noteDiv.style.marginTop = \"10px\";\n            noteDiv.style.fontStyle = \"italic\";\n            feedbackDiv.appendChild(noteDiv);\n        }\n    };\n\n});\n\nQualtrics.SurveyEngine.addOnReady(function()\n{\n\t\/*Place your JavaScript here to run when the page is fully displayed*\/\n\n});\n\nQualtrics.SurveyEngine.addOnUnload(function()\n{\n\t\/*Place your JavaScript here to run when the page is unloaded*\/\n\n});","QuestionText_Unsafe":"<img src=\"https:\/\/lmubwl.eu.qualtrics.com\/CP\/Graphic.php?IM=IM_eVRg7bwQgbC5FFc\" style=\"width: 424px; height: 565px;\" \/><br \/>\n<br \/>\nIs this image&nbsp;<strong>real&nbsp;<\/strong>or&nbsp;<strong>fake<\/strong>?<span style=\"color:#e74c3c;\">*<\/span>","DataExportTag":"feedback_real3","QuestionID":"QID229"}},{"SurveyID":"SV_cZsGe9lHlvOBspw","Element":"SQ","PrimaryAttribute":"QID23","SecondaryAttribute":"Hint:\u00a0Fake images often have anatomical errors. For example, people often have missing, extra, or..","TertiaryAttribute":null,"Payload":{"QuestionText":"<strong>Hint<\/strong>:&nbsp;Fake images often have <strong>anatomical errors<\/strong>. For example, people often have missing, extra, or merged fingers, nonexistent fingernails, and unlikely hand proportions.<br>\n<br>\nCan you spot the error in the image? <strong>Click on it to earn points<\/strong>!","DefaultChoices":false,"DataExportTag":"game_tip_1","QuestionID":"QID23","QuestionType":"DB","Selector":"GRB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Hint:\u00a0Fake images often have anatomical errors. For example, people often have missing, extra, or...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionJS":"Qualtrics.SurveyEngine.addOnload(function() {\n    console.log(\"Qualtrics onload function started\");\n\n    var that = this;\n    var container = this.getQuestionContainer();\n    var pageStartTime = Date.now();\n    var gameStartTime;\n    \n    function initializeGame() {\n        console.log(\"Initializing game\");\n        gameStartTime = Date.now();\n        \n        var existingImage = container.querySelector('img');\n        if (!existingImage) {\n            console.error(\"No image found in the question\");\n            return;\n        }\n        console.log(\"Found image:\", existingImage);\n        \n        \/\/ Create game elements\n        var gameElements = document.createElement('div');\n        gameElements.innerHTML = `\n            <div id=\"gameControls\" style=\"margin-bottom: 15px; display: flex; justify-content: center; align-items: center;\">\n                <div style=\"display: flex; gap: 20px;\">\n                    <div>Total Score: <span id=\"score\">0<\/span><\/div>\n                    <div id=\"timerContainer\">Time left: <span id=\"time\">30<\/span> <span id=\"secondsText\">seconds<\/span><\/div>\n                <\/div>\n            <\/div>\n            <div id=\"message\" style=\"margin-top: 15px; text-align: center; min-height: 20px;\"><\/div>\n        `;\n        \n        \/\/ Insert game elements before the image\n        existingImage.parentNode.insertBefore(gameElements, existingImage);\n        \n        \/\/ Create a container for the image and error region\n        var imageContainer = document.createElement('div');\n        imageContainer.style.position = 'relative';\n        imageContainer.style.display = 'inline-block';\n        existingImage.parentNode.insertBefore(imageContainer, existingImage);\n        imageContainer.appendChild(existingImage);\n        \n        \/\/ Create the error region circle\n        var errorRegionCircle = document.createElement('div');\n        errorRegionCircle.style.position = 'absolute';\n        errorRegionCircle.style.border = '2px solid red';\n        errorRegionCircle.style.borderRadius = '50%';\n        errorRegionCircle.style.pointerEvents = 'none';\n        errorRegionCircle.style.display = 'none';\n        imageContainer.appendChild(errorRegionCircle);\n        \n        \/\/ Initialize game variables\n        var score = parseInt(Qualtrics.SurveyEngine.getEmbeddedData('totalScore')) || 0;\n        var timeLeft = 30;\n        var gameEnded = false;\n        \n        \/\/ Update score display\n        document.getElementById('score').textContent = score;\n        \n        \/\/ Define the error region as percentages of image dimensions\n        var errorRegion = {xPercent: 0.5, yPercent: 0.75, radiusPercent: 0.12};\n        \n        \/\/ Function to update error region based on current image size\n        function updateErrorRegion() {\n            var imgRect = existingImage.getBoundingClientRect();\n            errorRegion.x = imgRect.width * errorRegion.xPercent;\n            errorRegion.y = imgRect.height * errorRegion.yPercent;\n            errorRegion.radius = Math.min(imgRect.width, imgRect.height) * errorRegion.radiusPercent;\n            updateErrorRegionCircle();\n        }\n        \n        \/\/ Update error region circle\n        function updateErrorRegionCircle() {\n            errorRegionCircle.style.left = (errorRegion.x - errorRegion.radius) + 'px';\n            errorRegionCircle.style.top = (errorRegion.y - errorRegion.radius) + 'px';\n            errorRegionCircle.style.width = (errorRegion.radius * 2) + 'px';\n            errorRegionCircle.style.height = (errorRegion.radius * 2) + 'px';\n        }\n        updateErrorRegionCircle();\n        \n        \/\/ DEBUG: Make error region visible from the start\n        \/\/errorRegionCircle.style.display = 'block';\n        \/\/errorRegionCircle.style.backgroundColor = 'rgba(255, 0, 0, 0.3)';\n        \n        \/\/ Initial update of error region\n        updateErrorRegion();\n        \n        \/\/ Add resize event listener to update error region when window size changes\n        window.addEventListener('resize', updateErrorRegion);\n        \n        \/\/ Start the timer\n        var timerInterval = setInterval(function() {\n            if (gameEnded) return;\n            timeLeft--;\n            var timerContainer = document.getElementById('timerContainer');\n            var timeElement = document.getElementById('time');\n            timeElement.textContent = timeLeft;\n            if (timeLeft <= 0) {\n                timerContainer.style.color = 'red';\n                endGame(\"Time's up!\", false);\n            }\n        }, 1000);\n        \n        \/\/ Handle image click\n        function handleImageClick(e) {\n            if (gameEnded) return;\n            console.log(\"Image clicked\");\n            var rect = e.target.getBoundingClientRect();\n            var x = e.clientX - rect.left;\n            var y = e.clientY - rect.top;\n            console.log(\"Click coordinates:\", x, y);\n            \n            if (isInErrorRegion(x, y)) {\n                score += 10;\n\t\t\t\tQualtrics.SurveyEngine.setEmbeddedData('game_tip_1_score', 10);\n                document.getElementById('score').textContent = score;\n                endGame(\"<strong>Correct! You found the error. You earned 10 points!<\/strong>\", true);\n            } else {\n                console.log(\"Click was not in the error region\");\n                showFeedback(\"<strong>Not quite! Try again.<\/strong>\", 'red', true);\n            }\n        }\n        \n        \/\/ Show feedback message\n        function showFeedback(message, color, temporary = false) {\n            var messageElement = document.getElementById('message');\n            messageElement.innerHTML = message;\n            messageElement.style.color = color;\n            if (temporary) {\n                setTimeout(() => {\n                    messageElement.textContent = '';\n                    messageElement.style.color = '';\n                }, 1500);\n            }\n        }\n        \n        \/\/ Check if click is within error region (circle)\n        function isInErrorRegion(x, y) {\n            var dx = x - errorRegion.x;\n            var dy = y - errorRegion.y;\n            return (dx*dx + dy*dy <= errorRegion.radius*errorRegion.radius);\n        }\n        \n        \/\/ End game function\n        function endGame(message, success) {\n            gameEnded = true;\n            clearInterval(timerInterval);\n            showFeedback(message, success ? 'green' : 'red', false);\n            existingImage.removeEventListener('click', handleImageClick);\n            existingImage.style.cursor = 'default';\n            \n            errorRegionCircle.style.display = 'block';\n            errorRegionCircle.style.backgroundColor = success ? 'rgba(0, 255, 0, 0.3)' : 'rgba(255, 0, 0, 0.3)';\n            console.log(\"endGame called with score:\", score)\n            try {\n                Qualtrics.SurveyEngine.setEmbeddedData('totalScore', score);\n                console.log(\"Score saved to embedded data:\", score);\n            } catch (error) {\n                console.error(\"Error saving score to embedded data:\", error);\n            }\n            console.log(\"Game ended:\", message);\n\t\t\tconsole.log(\"Score before message assignment:\", score);\n            \n            var gameTime = Date.now() - gameStartTime;\n            Qualtrics.SurveyEngine.setEmbeddedData('game_tip_1_gameTime', gameTime);\n            console.log(\"Time spent on this game:\", gameTime, \"ms\");\n            \n            var message = \"\";\n            if (score <= 10) {\n                message = \"&#127775; Thanks for participating! Spotting errors in fake images can be challenging. With more exposure, you'll likely get better at it.\";\n            } else if (score <= 30) {\n                message = \"&#128065;&#65039; Good eye! You've shown a solid ability to spot errors in fake images.\";\n            } else if (score <= 50) {\n                message = \"&#127942; Impressive results! You've demonstrated a keen ability to spot errors in fake images.\";\n            } else {\n                message = \"Thank you for participating in our AI image identification survey!\";\n            }\n\t\t\t\n\t\t\tQualtrics.SurveyEngine.setEmbeddedData('feedbackMessage', message);\n            \n            showNextButton();\n        }\n        \n        \/\/ Make the image clickable and change cursor to hand\n        existingImage.style.cursor = 'pointer';\n        existingImage.addEventListener('click', handleImageClick);\n\n        \/\/ Function to hide the Qualtrics Next button\n        function hideNextButton() {\n            var nextButton = document.querySelector('#NextButton');\n            if (nextButton) {\n                nextButton.style.display = 'none';\n            }\n        }\n\n        \/\/ Function to show the Qualtrics Next button\n        function showNextButton() {\n            var nextButton = document.querySelector('#NextButton');\n            if (nextButton) {\n                nextButton.style.display = '';\n            }\n        }\n\n        \/\/ Hide the Next button at the start of the game\n        hideNextButton();\n    }\n\n    \/\/ Call initializeGame after a short delay to ensure the DOM is ready\n    setTimeout(initializeGame, 500);\n    \n    \/\/ Add the onPageSubmit event handler\n    Qualtrics.SurveyEngine.addOnPageSubmit(function() {\n        var totalPageTime = Date.now() - pageStartTime;\n        Qualtrics.SurveyEngine.setEmbeddedData('game_tip_1_page_submit', totalPageTime);\n        console.log(\"Total time spent on page:\", totalPageTime, \"ms\");\n    });\n});","SubSelector":"WTXB","Graphics":"IM_3U3z9i3JQO1hvom","GraphicsDescription":"holding_hands_at_dinner.jpg"}},{"SurveyID":"SV_cZsGe9lHlvOBspw","Element":"SQ","PrimaryAttribute":"QID230","SecondaryAttribute":"Timing","TertiaryAttribute":null,"Payload":{"QuestionText":"Timing","DefaultChoices":false,"QuestionType":"Timing","Selector":"PageTimer","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","MinSeconds":2},"QuestionDescription":"Timing","Choices":{"1":{"Display":"First Click"},"2":{"Display":"Last Click"},"3":{"Display":"Page Submit"},"4":{"Display":"Click Count"}},"GradingData":[],"Language":[],"NextChoiceId":92,"NextAnswerId":1,"QuestionText_Unsafe":"Timing","DataExportTag":"feedback_real3_timer","QuestionID":"QID230"}},{"SurveyID":"SV_cZsGe9lHlvOBspw","Element":"SQ","PrimaryAttribute":"QID231","SecondaryAttribute":"Is this image\u00a0real\u00a0or\u00a0fake?*","TertiaryAttribute":null,"Payload":{"QuestionText":"<img src=\"https:\/\/lmubwl.eu.qualtrics.com\/CP\/Graphic.php?IM=IM_1OdVq7QqHrHbVVc\" style=\"width: 387px; height: 565px;\" \/><br \/>\n<br \/>\nIs this image&nbsp;<strong>real&nbsp;<\/strong>or&nbsp;<strong>fake<\/strong>?<span style=\"color:#e74c3c;\">*<\/span>","DefaultChoices":false,"QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Is this image\u00a0real\u00a0or\u00a0fake?*","Choices":{"1":{"Display":"Definitely real"},"2":{"Display":"Probably real"},"3":{"Display":"Probably fake"},"4":{"Display":"Definitely fake"}},"ChoiceOrder":["1","2","3","4"],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":5,"NextAnswerId":1,"QuestionJS":"Qualtrics.SurveyEngine.addOnload(function()\n{\n\t\/*Place your JavaScript here to run when the page loads*\/\n\t\/\/ Set up an array of correct answers\n    var correctAnswers = [\"1\", \"2\"]; \/\/ Change these to your two correct answer IDs\n\tvar answerSubmitted = false; \/\/ Track if an answer has been submitted\n\t\n\t\/\/ Add a CSS rule for shake animation\n    var style = document.createElement('style');\n    style.type = 'text\/css';\n    style.innerHTML = `\n    @keyframes shake {\n        0% { transform: translateX(0); }\n        10% { transform: translateX(-5px); }\n        20% { transform: translateX(5px); }\n        30% { transform: translateX(-5px); }\n        40% { transform: translateX(5px); }\n        50% { transform: translateX(-5px); }\n        60% { transform: translateX(5px); }\n        70% { transform: translateX(-5px); }\n        80% { transform: translateX(5px); }\n        90% { transform: translateX(-5px); }\n        100% { transform: translateX(0); }\n    }\n    .shake {\n        animation: shake 0.6s ease;\n    }`;\n    document.getElementsByTagName('head')[0].appendChild(style);\n    \n    \/\/ Create a div for feedback that will appear next to the image\n    var feedbackDiv = document.createElement(\"div\");\n    feedbackDiv.id = \"feedbackText\";\n    feedbackDiv.style.marginTop = \"10px\";\n    feedbackDiv.style.padding = \"10px\";\n    feedbackDiv.style.borderRadius = \"5px\";\n    feedbackDiv.style.display = \"none\"; \/\/ Initially hidden\n    \n    \/\/ Find the image container and add the feedback div after it\n    var imageElement = document.querySelector(\".QuestionText img\");\n    if (imageElement) {\n        imageElement.parentNode.insertBefore(feedbackDiv, imageElement.nextSibling);\n    }\n    \n    \/\/ When an answer is clicked\n    this.questionclick = function(event, element) {\n        if (element.type == \"radio\" && !answerSubmitted) {\n            \/\/ Set the flag to indicate an answer has been submitted\n            answerSubmitted = true;\n\t\t\t\n            \/\/ Get all the answer choices\n            var choices = document.getElementsByName(this.questionId);\n            \n            \/\/ Process the selection\n            var selectedChoice = element.parentElement;\n            \n            \/\/ Show the feedback div\n            feedbackDiv.style.display = \"block\";\n            \n            \/\/ Check if the selected answer is in our array of correct answers\n            if (correctAnswers.includes(element.value)) {\n                \/\/ Correct answer styling\n                selectedChoice.style.backgroundColor = \"#e6ffe6\"; \/\/ Light green\n                feedbackDiv.style.backgroundColor = \"#e6ffe6\"; \/\/ Light green\n                feedbackDiv.innerHTML = \"<strong>Correct!<\/strong> This is a <strong>REAL<\/strong> image.\";\n            } else {\n                \/\/ Incorrect answer styling\n                selectedChoice.style.backgroundColor = \"#ffe6e6\"; \/\/ Light red\n                feedbackDiv.style.backgroundColor = \"#ffe6e6\"; \/\/ Light red\n                feedbackDiv.innerHTML = \"<strong>Not quite.<\/strong> This is actually a <strong>REAL<\/strong> image.\";\n\t\t\t\t\/\/ Add shake animation to wrong answer\n                selectedChoice.classList.add(\"shake\");\n            }\n            \n            \/\/ Highlight all correct answers\n            for (var i = 0; i < choices.length; i++) {\n                if (correctAnswers.includes(choices[i].value)) {\n                    choices[i].parentElement.style.backgroundColor = \"#e6ffe6\"; \/\/ Light green\n                }\n            }\n            \n            \/\/ Disable all radio buttons to prevent further selection\n            for (var i = 0; i < choices.length; i++) {\n                choices[i].disabled = true;\n                \n                \/\/ Add visual indication that the option is disabled\n                if (!correctAnswers.includes(choices[i].value) && choices[i].value != element.value) {\n                    choices[i].parentElement.style.opacity = \"0.5\";\n                }\n            }\n            \n            \/\/ Add a note that the answer has been recorded\n            var noteDiv = document.createElement(\"div\");\n            noteDiv.innerHTML = \"<em>Your answer has been recorded. Please continue to the next question.<\/em>\";\n            noteDiv.style.marginTop = \"10px\";\n            noteDiv.style.fontStyle = \"italic\";\n            feedbackDiv.appendChild(noteDiv);\n        }\n    };\n\n});\n\nQualtrics.SurveyEngine.addOnReady(function()\n{\n\t\/*Place your JavaScript here to run when the page is fully displayed*\/\n\n});\n\nQualtrics.SurveyEngine.addOnUnload(function()\n{\n\t\/*Place your JavaScript here to run when the page is unloaded*\/\n\n});","QuestionText_Unsafe":"<img src=\"https:\/\/lmubwl.eu.qualtrics.com\/CP\/Graphic.php?IM=IM_eVRg7bwQgbC5FFc\" style=\"width: 424px; height: 565px;\" \/><br \/>\n<br \/>\nIs this image&nbsp;<strong>real&nbsp;<\/strong>or&nbsp;<strong>fake<\/strong>?<span style=\"color:#e74c3c;\">*<\/span>","DataExportTag":"feedback_real4","QuestionID":"QID231"}},{"SurveyID":"SV_cZsGe9lHlvOBspw","Element":"SQ","PrimaryAttribute":"QID232","SecondaryAttribute":"Timing","TertiaryAttribute":null,"Payload":{"QuestionText":"Timing","DefaultChoices":false,"QuestionType":"Timing","Selector":"PageTimer","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","MinSeconds":2},"QuestionDescription":"Timing","Choices":{"1":{"Display":"First Click"},"2":{"Display":"Last Click"},"3":{"Display":"Page Submit"},"4":{"Display":"Click Count"}},"GradingData":[],"Language":[],"NextChoiceId":92,"NextAnswerId":1,"QuestionText_Unsafe":"Timing","DataExportTag":"feedback_real4_timer","QuestionID":"QID232"}},{"SurveyID":"SV_cZsGe9lHlvOBspw","Element":"SQ","PrimaryAttribute":"QID233","SecondaryAttribute":"Is this image\u00a0real\u00a0or\u00a0fake?*","TertiaryAttribute":null,"Payload":{"QuestionText":"<img src=\"https:\/\/lmubwl.eu.qualtrics.com\/CP\/Graphic.php?IM=IM_6gSSGXwXb171EX4\" style=\"width: 376px; height: 565px;\" \/><br \/>\n<br \/>\nIs this image&nbsp;<strong>real&nbsp;<\/strong>or&nbsp;<strong>fake<\/strong>?<span style=\"color:#e74c3c;\">*<\/span>","DefaultChoices":false,"QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Is this image\u00a0real\u00a0or\u00a0fake?*","Choices":{"1":{"Display":"Definitely real"},"2":{"Display":"Probably real"},"3":{"Display":"Probably fake"},"4":{"Display":"Definitely fake"}},"ChoiceOrder":["1","2","3","4"],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":5,"NextAnswerId":1,"QuestionJS":"Qualtrics.SurveyEngine.addOnload(function()\n{\n\t\/*Place your JavaScript here to run when the page loads*\/\n\t\/\/ Set up an array of correct answers\n    var correctAnswers = [\"1\", \"2\"]; \/\/ Change these to your two correct answer IDs\n\tvar answerSubmitted = false; \/\/ Track if an answer has been submitted\n\t\n\t\/\/ Add a CSS rule for shake animation\n    var style = document.createElement('style');\n    style.type = 'text\/css';\n    style.innerHTML = `\n    @keyframes shake {\n        0% { transform: translateX(0); }\n        10% { transform: translateX(-5px); }\n        20% { transform: translateX(5px); }\n        30% { transform: translateX(-5px); }\n        40% { transform: translateX(5px); }\n        50% { transform: translateX(-5px); }\n        60% { transform: translateX(5px); }\n        70% { transform: translateX(-5px); }\n        80% { transform: translateX(5px); }\n        90% { transform: translateX(-5px); }\n        100% { transform: translateX(0); }\n    }\n    .shake {\n        animation: shake 0.6s ease;\n    }`;\n    document.getElementsByTagName('head')[0].appendChild(style);\n    \n    \/\/ Create a div for feedback that will appear next to the image\n    var feedbackDiv = document.createElement(\"div\");\n    feedbackDiv.id = \"feedbackText\";\n    feedbackDiv.style.marginTop = \"10px\";\n    feedbackDiv.style.padding = \"10px\";\n    feedbackDiv.style.borderRadius = \"5px\";\n    feedbackDiv.style.display = \"none\"; \/\/ Initially hidden\n    \n    \/\/ Find the image container and add the feedback div after it\n    var imageElement = document.querySelector(\".QuestionText img\");\n    if (imageElement) {\n        imageElement.parentNode.insertBefore(feedbackDiv, imageElement.nextSibling);\n    }\n    \n    \/\/ When an answer is clicked\n    this.questionclick = function(event, element) {\n        if (element.type == \"radio\" && !answerSubmitted) {\n            \/\/ Set the flag to indicate an answer has been submitted\n            answerSubmitted = true;\n\t\t\t\n            \/\/ Get all the answer choices\n            var choices = document.getElementsByName(this.questionId);\n            \n            \/\/ Process the selection\n            var selectedChoice = element.parentElement;\n            \n            \/\/ Show the feedback div\n            feedbackDiv.style.display = \"block\";\n            \n            \/\/ Check if the selected answer is in our array of correct answers\n            if (correctAnswers.includes(element.value)) {\n                \/\/ Correct answer styling\n                selectedChoice.style.backgroundColor = \"#e6ffe6\"; \/\/ Light green\n                feedbackDiv.style.backgroundColor = \"#e6ffe6\"; \/\/ Light green\n                feedbackDiv.innerHTML = \"<strong>Correct!<\/strong> This is a <strong>REAL<\/strong> image.\";\n            } else {\n                \/\/ Incorrect answer styling\n                selectedChoice.style.backgroundColor = \"#ffe6e6\"; \/\/ Light red\n                feedbackDiv.style.backgroundColor = \"#ffe6e6\"; \/\/ Light red\n                feedbackDiv.innerHTML = \"<strong>Not quite.<\/strong> This is actually a <strong>REAL<\/strong> image.\";\n\t\t\t\t\/\/ Add shake animation to wrong answer\n                selectedChoice.classList.add(\"shake\");\n            }\n            \n            \/\/ Highlight all correct answers\n            for (var i = 0; i < choices.length; i++) {\n                if (correctAnswers.includes(choices[i].value)) {\n                    choices[i].parentElement.style.backgroundColor = \"#e6ffe6\"; \/\/ Light green\n                }\n            }\n            \n            \/\/ Disable all radio buttons to prevent further selection\n            for (var i = 0; i < choices.length; i++) {\n                choices[i].disabled = true;\n                \n                \/\/ Add visual indication that the option is disabled\n                if (!correctAnswers.includes(choices[i].value) && choices[i].value != element.value) {\n                    choices[i].parentElement.style.opacity = \"0.5\";\n                }\n            }\n            \n            \/\/ Add a note that the answer has been recorded\n            var noteDiv = document.createElement(\"div\");\n            noteDiv.innerHTML = \"<em>Your answer has been recorded. Please continue to the next question.<\/em>\";\n            noteDiv.style.marginTop = \"10px\";\n            noteDiv.style.fontStyle = \"italic\";\n            feedbackDiv.appendChild(noteDiv);\n        }\n    };\n\n});\n\nQualtrics.SurveyEngine.addOnReady(function()\n{\n\t\/*Place your JavaScript here to run when the page is fully displayed*\/\n\n});\n\nQualtrics.SurveyEngine.addOnUnload(function()\n{\n\t\/*Place your JavaScript here to run when the page is unloaded*\/\n\n});","QuestionText_Unsafe":"<img src=\"https:\/\/lmubwl.eu.qualtrics.com\/CP\/Graphic.php?IM=IM_eVRg7bwQgbC5FFc\" style=\"width: 424px; height: 565px;\" \/><br \/>\n<br \/>\nIs this image&nbsp;<strong>real&nbsp;<\/strong>or&nbsp;<strong>fake<\/strong>?<span style=\"color:#e74c3c;\">*<\/span>","DataExportTag":"feedback_real5","QuestionID":"QID233"}},{"SurveyID":"SV_cZsGe9lHlvOBspw","Element":"SQ","PrimaryAttribute":"QID234","SecondaryAttribute":"Timing","TertiaryAttribute":null,"Payload":{"QuestionText":"Timing","DefaultChoices":false,"QuestionType":"Timing","Selector":"PageTimer","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","MinSeconds":2},"QuestionDescription":"Timing","Choices":{"1":{"Display":"First Click"},"2":{"Display":"Last Click"},"3":{"Display":"Page Submit"},"4":{"Display":"Click Count"}},"GradingData":[],"Language":[],"NextChoiceId":92,"NextAnswerId":1,"QuestionText_Unsafe":"Timing","DataExportTag":"feedback_real5_timer","QuestionID":"QID234"}},{"SurveyID":"SV_cZsGe9lHlvOBspw","Element":"SQ","PrimaryAttribute":"QID235","SecondaryAttribute":"Thank you! QUESTIONS OR CONCERNS:\u00a0If you have any questions, please feel free to contact a member..","TertiaryAttribute":null,"Payload":{"QuestionText":"<div style=\"text-align: center;\"><strong>Thank you!<\/strong><\/div>\n<strong>QUESTIONS OR CONCERNS:&nbsp;<\/strong>If you have any questions, please feel free to contact a member of the research team using the provided contact information.<br \/>\nDominique Geissler and Stefan Feuerriegel<br \/>\nInstitute of AI in Management, School of Management, LMU Munich<br \/>\n<br \/>\n<strong>Contact<\/strong>: d.geissler@lmu.de<br \/>\n<br \/>\nPlease click the button below to be redirected to Prolific and register your submission.<br \/>\n&nbsp;","DefaultChoices":false,"DataExportTag":"thank_you","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Thank you! QUESTIONS OR CONCERNS:\u00a0If you have any questions, please feel free to contact a member...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID235"}},{"SurveyID":"SV_cZsGe9lHlvOBspw","Element":"SQ","PrimaryAttribute":"QID236","SecondaryAttribute":"Timing","TertiaryAttribute":null,"Payload":{"QuestionText":"Timing","DefaultChoices":false,"DataExportTag":"debrief_timer","QuestionType":"Timing","Selector":"PageTimer","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","MinSeconds":"0","MaxSeconds":"0"},"QuestionDescription":"Timing","Choices":{"1":{"Display":"First Click"},"2":{"Display":"Last Click"},"3":{"Display":"Page Submit"},"4":{"Display":"Click Count"}},"GradingData":[],"Language":[],"NextChoiceId":32,"NextAnswerId":1,"QuestionID":"QID236"}},{"SurveyID":"SV_cZsGe9lHlvOBspw","Element":"SQ","PrimaryAttribute":"QID237","SecondaryAttribute":"Timing","TertiaryAttribute":null,"Payload":{"QuestionText":"Timing","DefaultChoices":false,"DataExportTag":"thank_you_timer","QuestionType":"Timing","Selector":"PageTimer","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","MinSeconds":"0","MaxSeconds":"0"},"QuestionDescription":"Timing","Choices":{"1":{"Display":"First Click"},"2":{"Display":"Last Click"},"3":{"Display":"Page Submit"},"4":{"Display":"Click Count"}},"GradingData":[],"Language":[],"NextChoiceId":20,"NextAnswerId":1,"QuestionID":"QID237"}},{"SurveyID":"SV_cZsGe9lHlvOBspw","Element":"SQ","PrimaryAttribute":"QID24","SecondaryAttribute":"How to detect fake images Some of the images you see online could be generated by artificial inte...","TertiaryAttribute":null,"Payload":{"QuestionText":"<div style=\"text-align: center;\"><strong>How to detect fake images<\/strong><\/div>\n\n<div style=\"text-align: left;\"><br \/>\nSome of the images you see online could be generated by artificial intelligence (AI) and are hence <strong>fake<\/strong>. Here, we show you <strong>5 ways<\/strong>&nbsp;<strong>to detect fake images<\/strong> that were generated by AI. Each hint is accompanied with an example image.<br \/>\n<br \/>\nLater, we will ask you to apply your knowledge in a&nbsp;<strong>fake image detection task<\/strong>. Please read the following hints very carefully.&nbsp;&nbsp;<\/div>","DefaultChoices":false,"DataExportTag":"visual_tip_intro","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"How to detect fake images Some of the images you see online could be generated by artificial inte...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID24","QuestionJS":"Qualtrics.SurveyEngine.addOnload(function()\n{\n\t\/*Place your JavaScript here to run when the page loads*\/\n\tvar start = Date.now();\n\t\n\tQualtrics.SurveyEngine.addOnPageSubmit(function() {\n\t\tQualtrics.SurveyEngine.setEmbeddedData('visual_tip_intro_page_submit',Date.now()-start);\n\t});\n\n});\n\nQualtrics.SurveyEngine.addOnReady(function()\n{\n\t\/*Place your JavaScript here to run when the page is fully displayed*\/\n\tthis.hideNextButton();\n\tsetTimeout(function() { jQuery(\"#NextButton\").show(); },2000);\n\n});\n\nQualtrics.SurveyEngine.addOnUnload(function()\n{\n\t\/*Place your JavaScript here to run when the page is unloaded*\/\n\n});"}},{"SurveyID":"SV_cZsGe9lHlvOBspw","Element":"SQ","PrimaryAttribute":"QID25","SecondaryAttribute":"\ud83c\udfae Let's play a game! \ud83c\udfae \u00a0 \u00a0 Some of the images you see online could be generated by artificia","TertiaryAttribute":null,"Payload":{"QuestionText":"<p style=\"text-align: center;\">\ud83c\udfae <strong>Let&#39;s play a game!<\/strong> \ud83c\udfae<\/p>\n&nbsp;\n\n<p>&nbsp;<\/p>\n\n<p>Some of the images you see online could be generated by artificial intelligence (AI) and are hence <strong>fake<\/strong> \ud83e\udd16. Here, we show you <strong>5 ways<\/strong> <strong>to detect fake images<\/strong> that were generated by AI. Each hint is accompanied by an example image. How the <strong>game<\/strong> works:<\/p>\n&nbsp;\n\n<p>&nbsp;<\/p>\n\n<ul>\n\t<li>\ud83d\udcd5 <strong>Read<\/strong> the hint.<\/li>\n\t<li>\ud83d\uddb1\ufe0f <strong>Click<\/strong> on the area of the image where you locate the mentioned error.<\/li>\n\t<li>\u2705 If you find the error, you will <strong>receive 10 points<\/strong>.<\/li>\n\t<li>\u23f3 If the timer runs out before you find the error, you will not get any points.<\/li>\n\t<li>\ud83c\udfc6 You can <strong>collect up to 50 points<\/strong> in total.<\/li>\n\t<li>\u23f1\ufe0f You have <strong>30 seconds<\/strong> per image.<\/li>\n<\/ul>\n&nbsp;\n\n<p>&nbsp;<\/p>\n\n<p>Later, we will ask you to apply your knowledge in a <strong>fake image detection task<\/strong> \ud83d\udd75\ufe0f&zwj;\u2640\ufe0f.<\/p>","DefaultChoices":false,"DataExportTag":"intervention_4_intro","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"\ud83c\udfae Let's play a game! \ud83c\udfae \u00a0 \u00a0 Some of the images you see online could be generated by artificial int...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID25","QuestionJS":"Qualtrics.SurveyEngine.addOnload(function()\n{\n\t\/*Place your JavaScript here to run when the page loads*\/\n\tvar start = Date.now();\n\t\n\tQualtrics.SurveyEngine.addOnPageSubmit(function() {\n\t\tQualtrics.SurveyEngine.setEmbeddedData('game_tip_intro_page_submit',Date.now()-start);\n\t});\n});\n\nQualtrics.SurveyEngine.addOnReady(function()\n{\n\t\/*Place your JavaScript here to run when the page is fully displayed*\/\nthis.hideNextButton();\n\tsetTimeout(function() { jQuery(\"#NextButton\").show(); },4000);\n});\n\nQualtrics.SurveyEngine.addOnUnload(function()\n{\n\t\/*Place your JavaScript here to run when the page is unloaded*\/\n\n});"}},{"SurveyID":"SV_cZsGe9lHlvOBspw","Element":"SQ","PrimaryAttribute":"QID26","SecondaryAttribute":"Hint:\u00a0Fake images often look a bit too perfect. People may have glossy, shiny skin, windswept hai..","TertiaryAttribute":null,"Payload":{"QuestionText":"<strong>Hint<\/strong>:&nbsp;Fake images often look a bit<strong> too perfect<\/strong>. People may have glossy, shiny skin, windswept hair, and they may look like a photo in a magazine or a scene from a movie. Sometimes, parts of an image have a different level of detail or vibrancy compared to the rest.&nbsp;<br>\n<br>\nCan you spot the error in the image? <strong>Click on it to earn points<\/strong>!","DefaultChoices":false,"DataExportTag":"game_tip_2","QuestionType":"DB","Selector":"GRB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Hint:\u00a0Fake images often look a bit too perfect. People may have glossy, shiny skin, windswept hai...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID26","QuestionJS":"Qualtrics.SurveyEngine.addOnload(function() {\n    console.log(\"Qualtrics onload function started\");\n\n    var that = this;\n    var container = this.getQuestionContainer();\n    var pageStartTime = Date.now(); \/\/ Start timing for the entire page\n    var gameStartTime; \/\/ Will be set when the game initializes\n    \n    function initializeGame() {\n        console.log(\"Initializing game\");\n        gameStartTime = Date.now(); \/\/ Start timing for this specific game\n        \n        \/\/ Find the existing image\n        var existingImage = container.querySelector('img');\n        if (!existingImage) {\n            console.error(\"No image found in the question\");\n            return;\n        }\n        console.log(\"Found image:\", existingImage);\n        \n        \/\/ Create game elements\n        var gameElements = document.createElement('div');\n        gameElements.innerHTML = `\n            <div id=\"gameControls\" style=\"margin-bottom: 15px; display: flex; justify-content: center; align-items: center;\">\n                <div style=\"display: flex; gap: 20px;\">\n                    <div>Total Score: <span id=\"score\">0<\/span><\/div>\n                    <div id=\"timerContainer\">Time left: <span id=\"time\">30<\/span> <span id=\"secondsText\">seconds<\/span><\/div>\n                <\/div>\n            <\/div>\n            <div id=\"message\" style=\"margin-top: 15px; text-align: center; min-height: 20px;\"><\/div>\n        `;\n        \n        \/\/ Insert game elements before the image\n        existingImage.parentNode.insertBefore(gameElements, existingImage);\n        \n        \/\/ Create a container for the image and error region\n        var imageContainer = document.createElement('div');\n        imageContainer.style.position = 'relative';\n        imageContainer.style.display = 'inline-block';\n        existingImage.parentNode.insertBefore(imageContainer, existingImage);\n        imageContainer.appendChild(existingImage);\n        \n        \/\/ Create the error region circle\n        var errorRegionCircle = document.createElement('div');\n        errorRegionCircle.style.position = 'absolute';\n        errorRegionCircle.style.border = '2px solid red';\n        errorRegionCircle.style.borderRadius = '50%';\n        errorRegionCircle.style.pointerEvents = 'none'; \/\/ Ensure clicks pass through to the image\n        errorRegionCircle.style.display = 'none'; \/\/ Initially hidden\n        imageContainer.appendChild(errorRegionCircle);\n        \n        \/\/ Initialize game variables\n        var score = parseInt(Qualtrics.SurveyEngine.getEmbeddedData('totalScore')) || 0;\n        var timeLeft = 30;\n        var gameEnded = false;\n        \n        \/\/ Update score display\n        document.getElementById('score').textContent = score;\n        \n        \/\/ Define the error region as percentages of image dimensions\n        var errorRegion = {xPercent: 0.525, yPercent: 0.485, radiusPercent: 0.075};\n        \n        \/\/ Function to update error region based on current image size\n        function updateErrorRegion() {\n            var imgRect = existingImage.getBoundingClientRect();\n            errorRegion.x = imgRect.width * errorRegion.xPercent;\n            errorRegion.y = imgRect.height * errorRegion.yPercent;\n            errorRegion.radius = Math.min(imgRect.width, imgRect.height) * errorRegion.radiusPercent;\n            updateErrorRegionCircle();\n        }\n        \n        \/\/ Update error region circle\n        function updateErrorRegionCircle() {\n            errorRegionCircle.style.left = (errorRegion.x - errorRegion.radius) + 'px';\n            errorRegionCircle.style.top = (errorRegion.y - errorRegion.radius) + 'px';\n            errorRegionCircle.style.width = (errorRegion.radius * 2) + 'px';\n            errorRegionCircle.style.height = (errorRegion.radius * 2) + 'px';\n        }\n        \n        \/\/ Initial update of error region\n        updateErrorRegion();\n        \n        \/\/ Add resize event listener to update error region when window size changes\n        window.addEventListener('resize', updateErrorRegion);\n        \n        \/\/ DEBUG: Make error region visible from the start\n        \/\/errorRegionCircle.style.display = 'block';\n        \/\/errorRegionCircle.style.backgroundColor = 'rgba(255, 0, 0, 0.3)';\n        \n        \/\/ Start the timer\n        var timerInterval = setInterval(function() {\n            if (gameEnded) return;\n            timeLeft--;\n            var timerContainer = document.getElementById('timerContainer');\n            var timeElement = document.getElementById('time');\n            timeElement.textContent = timeLeft;\n            if (timeLeft <= 0) {\n                timerContainer.style.color = 'red';\n                endGame(\"Time's up!\", false);\n            }\n        }, 1000);\n        \n        \/\/ Handle image click\n        function handleImageClick(e) {\n            if (gameEnded) return;\n            console.log(\"Image clicked\");\n            var rect = e.target.getBoundingClientRect();\n            var x = e.clientX - rect.left;\n            var y = e.clientY - rect.top;\n            console.log(\"Click coordinates:\", x, y);\n            \n            if (isInErrorRegion(x, y)) {\n                score += 10;\n                document.getElementById('score').textContent = score;\n\t\t\t\tQualtrics.SurveyEngine.setEmbeddedData('game_tip_2_score', 10);\n                endGame(\"<strong>Correct! You found the error. You earned 10 points!<\/strong>\", true);\n            } else {\n                console.log(\"Click was not in the error region\");\n                showFeedback(\"<strong>Not quite! Try again.<\/strong>\", 'red', true);\n            }\n        }\n        \n        \/\/ Show feedback message\n        function showFeedback(message, color, temporary = false) {\n            var messageElement = document.getElementById('message');\n            messageElement.innerHTML = message;\n            messageElement.style.color = color;\n            if (temporary) {\n                setTimeout(() => {\n                    messageElement.textContent = '';\n                    messageElement.style.color = '';\n                }, 1500); \/\/ Clear the message after 1.5 seconds if it's temporary\n            }\n        }\n        \n        \/\/ Check if click is within error region (circle)\n        function isInErrorRegion(x, y) {\n            var dx = x - errorRegion.x;\n            var dy = y - errorRegion.y;\n            return (dx*dx + dy*dy <= errorRegion.radius*errorRegion.radius);\n        }\n        \n        \/\/ End game function\n        function endGame(message, success) {\n            gameEnded = true;\n            clearInterval(timerInterval);\n            showFeedback(message, success ? 'green' : 'red', false);\n            existingImage.removeEventListener('click', handleImageClick);\n            existingImage.style.cursor = 'default'; \/\/ Change cursor back to default when game ends\n            \n            \/\/ Show the error region circle\n            errorRegionCircle.style.display = 'block';\n            errorRegionCircle.style.backgroundColor = success ? 'rgba(0, 255, 0, 0.3)' : 'rgba(255, 0, 0, 0.3)';\n            \n            \/\/ Save the score to Embedded Data\n            try {\n                Qualtrics.SurveyEngine.setEmbeddedData('totalScore', score);\n                console.log(\"Score saved to embedded data:\", score);\n            } catch (error) {\n                console.error(\"Error saving score to embedded data:\", error);\n            }\n            console.log(\"Game ended:\", message);\n            \n            \/\/ Record the time spent on this game\n            var gameTime = Date.now() - gameStartTime;\n            Qualtrics.SurveyEngine.setEmbeddedData('game_tip_2_gameTime', gameTime);\n            console.log(\"Time spent on this game:\", gameTime, \"ms\");\n\n            var message = \"\";\n\n            if (score <= 10) {\n                 message = \"&#127775; Thanks for participating! Spotting errors in fake images can be challenging. With more exposure, you'll likely get better at it.\";\n            } else if (score <= 30) {\n                  message = \"&#128065;&#65039; Good eye! You've shown a solid ability to spot errors in fake images.\";\n            } else if (score <= 50) {\n                 message = \"&#127942; Impressive results! You've demonstrated a keen ability to spot errors in fake images.\";\n            } else {\n                 message = \"Thank you for participating in our AI image identification survey!\";\n            }\n\t\t\t\n            Qualtrics.SurveyEngine.setEmbeddedData('feedbackMessage', message);\n            \/\/ Show the Qualtrics Next button\n            showNextButton();\n        }\n        \n        \/\/ Make the image clickable and change cursor to hand\n        existingImage.style.cursor = 'pointer';\n        existingImage.addEventListener('click', handleImageClick);\n\n        \/\/ Function to hide the Qualtrics Next button\n        function hideNextButton() {\n            var nextButton = document.querySelector('#NextButton');\n            if (nextButton) {\n                nextButton.style.display = 'none';\n            }\n        }\n\n        \/\/ Function to show the Qualtrics Next button\n        function showNextButton() {\n            var nextButton = document.querySelector('#NextButton');\n            if (nextButton) {\n                nextButton.style.display = '';\n            }\n        }\n\n        \/\/ Hide the Next button at the start of the game\n        hideNextButton();\n    }\n\n    \/\/ Call initializeGame after a short delay to ensure the DOM is ready\n    setTimeout(initializeGame, 500);\n    \n    \/\/ Add the onPageSubmit event handler\n    Qualtrics.SurveyEngine.addOnPageSubmit(function() {\n        var totalPageTime = Date.now() - pageStartTime;\n        Qualtrics.SurveyEngine.setEmbeddedData('game_tip_2_page_submit', totalPageTime);\n        console.log(\"Total time spent on page:\", totalPageTime, \"ms\");\n    });\n});","SubSelector":"WTXB","Graphics":"IM_VJngiNBKQQiDbZZ","GraphicsDescription":"woman_on_street.jpg"}},{"SurveyID":"SV_cZsGe9lHlvOBspw","Element":"SQ","PrimaryAttribute":"QID27","SecondaryAttribute":"Hint: Fake images often have functional errors. Image generators do not have a structural underst...","TertiaryAttribute":null,"Payload":{"QuestionText":"<strong>Hint<\/strong>: Fake images often have<strong> functional errors<\/strong>. Image generators do not have a structural understanding of how objects in the world work and interact with each other. This can cause composition errors, dysfunctional objects, and atypical designs. Looking closely may also reveal distorted and unresolved details or incomprehensible text and logos.","DefaultChoices":false,"DataExportTag":"textual_tip_3","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Hint: Fake images often have functional errors. Image generators do not have a structural underst...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID27","QuestionJS":"Qualtrics.SurveyEngine.addOnload(function()\n{\n\t\/*Place your JavaScript here to run when the page loads*\/\n\tvar start = Date.now();\n\t\n\tQualtrics.SurveyEngine.addOnPageSubmit(function() {\n\t\tQualtrics.SurveyEngine.setEmbeddedData('textual_tip_3_page_submit',Date.now()-start);\n\t});\n\n});\n\nQualtrics.SurveyEngine.addOnReady(function()\n{\n\t\/*Place your JavaScript here to run when the page is fully displayed*\/\n\tthis.hideNextButton();\n\tsetTimeout(function() { jQuery(\"#NextButton\").show(); },5000);\n\n});\n\nQualtrics.SurveyEngine.addOnUnload(function()\n{\n\t\/*Place your JavaScript here to run when the page is unloaded*\/\n\n});"}},{"SurveyID":"SV_cZsGe9lHlvOBspw","Element":"SQ","PrimaryAttribute":"QID28","SecondaryAttribute":"Hint: Fake images can produce subtle artifacts that are inconsistent with the laws of physics. Th...","TertiaryAttribute":null,"Payload":{"QuestionText":"<strong>Hint<\/strong>: Fake images can produce subtle <strong>artifacts that are inconsistent with the laws of physics<\/strong>. These include inaccurate shadows, reflections of alternative realities, and depth and perspective issues.","DefaultChoices":false,"DataExportTag":"textual_tip_4","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Hint: Fake images can produce subtle artifacts that a