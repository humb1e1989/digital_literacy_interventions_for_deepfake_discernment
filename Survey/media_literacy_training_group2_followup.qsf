Date.now();\n\t\n\tQualtrics.SurveyEngine.addOnPageSubmit(function() {\n\t\tQualtrics.SurveyEngine.setEmbeddedData('textual_tip_5_page_submit',Date.now()-start);\n\t});\n\n});\n\nQualtrics.SurveyEngine.addOnReady(function()\n{\n\t\/*Place your JavaScript here to run when the page is fully displayed*\/\n\tthis.hideNextButton();\n\tsetTimeout(function() { jQuery(\"#NextButton\").show(); },5000);\n\n});\n\nQualtrics.SurveyEngine.addOnUnload(function()\n{\n\t\/*Place your JavaScript here to run when the page is unloaded*\/\n\n});"}},{"SurveyID":"SV_cZsGe9lHlvOBspw","Element":"SQ","PrimaryAttribute":"QID3","SecondaryAttribute":"Environmental issues are increasingly becoming a global concern, and many people are more mindful...","TertiaryAttribute":null,"Payload":{"QuestionText":"Environmental issues are increasingly becoming a global concern, and many people are more mindful of how their actions impact the planet. We appreciate your help with this survey and are interested in whether you take enough time to read the survey directions and questions carefully before you provide your answers. To confirm that you're reading the instructions, please choose both 'Recycling' and 'Composting' from the options below, even if you do not participate in either. What actions are you asked to select?<span style=\"color:#FF0000;\">*<\/span>","DefaultChoices":false,"DataExportTag":"Attention check 1","QuestionID":"QID3","QuestionType":"MC","Selector":"MAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Environmental issues are increasingly becoming a global concern, and many people are more mindful...","Choices":{"4":{"Display":"Recycling"},"5":{"Display":"Composting"},"6":{"Display":"Using public transportation"},"7":{"Display":"Reducing water usage"},"8":{"Display":"Donating clothes"},"9":{"Display":"Eating less meat"},"10":{"Display":"I do not take any specific actions"}},"ChoiceOrder":["4","5","6","7","8","9","10"],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":11,"NextAnswerId":1,"Randomization":{"Type":"Advanced","Advanced":{"FixedOrder":["{~Randomized~}","{~Randomized~}","{~Randomized~}","{~Randomized~}","{~Randomized~}","{~Randomized~}"],"RandomizeAll":["4","5","6","7","8","9"],"RandomSubSet":[],"ScaleReversal":[],"Undisplayed":["10"],"TotalRandSubset":0},"ConsistentScaleReversal":false,"EvenPresentation":false,"TotalRandSubset":""}}},{"SurveyID":"SV_cZsGe9lHlvOBspw","Element":"SQ","PrimaryAttribute":"QID30","SecondaryAttribute":"Hint:\u00a0Fake images may have sociocultural errors. For example, the images may show scenarios that...","TertiaryAttribute":null,"Payload":{"QuestionText":"<strong>Hint<\/strong>:&nbsp;Fake images may have <strong>sociocultural errors<\/strong>. For example, the images may show scenarios that are inappropriate, unlikely to be seen in the real world, violate subtle rules specific to different cultures, or are historically inaccurate.&nbsp;<br>\n<br>\nIn the image below, the scenario is <strong>highly unlikely<\/strong>.","DefaultChoices":false,"DataExportTag":"visual_tip_5","QuestionType":"DB","Selector":"GRB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Hint:\u00a0Fake images may have sociocultural errors. For example, the images may show scenarios that...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID30","SubSelector":"WTXB","Graphics":"IM_B6bCU8LQeSMFL5L","GraphicsDescription":"pope-wearing-balenciaga-jacket.jpg","QuestionJS":"Qualtrics.SurveyEngine.addOnload(function()\n{\n\t\/*Place your JavaScript here to run when the page loads*\/\n\tvar start = Date.now();\n\t\n\tQualtrics.SurveyEngine.addOnPageSubmit(function() {\n\t\tQualtrics.SurveyEngine.setEmbeddedData('visual_tip_5_page_submit',Date.now()-start);\n\t});\n\n});\n\nQualtrics.SurveyEngine.addOnReady(function()\n{\n\t\/*Place your JavaScript here to run when the page is fully displayed*\/\n\tthis.hideNextButton();\n\tsetTimeout(function() { jQuery(\"#NextButton\").show(); },5000);\n\n});\n\nQualtrics.SurveyEngine.addOnUnload(function()\n{\n\t\/*Place your JavaScript here to run when the page is unloaded*\/\n\n});"}},{"SurveyID":"SV_cZsGe9lHlvOBspw","Element":"SQ","PrimaryAttribute":"QID31","SecondaryAttribute":"Hint:\u00a0Fake images can produce subtle artifacts that are inconsistent with the laws of physics. Th..","TertiaryAttribute":null,"Payload":{"QuestionText":"<strong>Hint<\/strong>:&nbsp;Fake images can produce subtle <strong>artifacts that are inconsistent with the laws of physics<\/strong>. These include inaccurate shadows, reflections of alternative realities, and depth and perspective issues.<br>\n<br>\nIn the image below, the<strong> reflection of the man doesn't match the man in front of the mirror<\/strong>. The wrong arm is holding the toothbrush and the toothbrush should be facing a different direction.","DefaultChoices":false,"DataExportTag":"visual_tip_4","QuestionType":"DB","Selector":"GRB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Hint:\u00a0Fake images can produce subtle artifacts that are inconsistent with the laws of physics. Th...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID31","SubSelector":"WTXB","Graphics":"IM_s85s22BAa1a9rqS","GraphicsDescription":"man_brushing_teeth.jpg","QuestionJS":"Qualtrics.SurveyEngine.addOnload(function()\n{\n\t\/*Place your JavaScript here to run when the page loads*\/\n\tvar start = Date.now();\n\t\n\tQualtrics.SurveyEngine.addOnPageSubmit(function() {\n\t\tQualtrics.SurveyEngine.setEmbeddedData('visual_tip_4_page_submit',Date.now()-start);\n\t});\n\n});\n\nQualtrics.SurveyEngine.addOnReady(function()\n{\n\t\/*Place your JavaScript here to run when the page is fully displayed*\/\n\tthis.hideNextButton();\n\tsetTimeout(function() { jQuery(\"#NextButton\").show(); },5000);\n\n});\n\nQualtrics.SurveyEngine.addOnUnload(function()\n{\n\t\/*Place your JavaScript here to run when the page is unloaded*\/\n\n});"}},{"SurveyID":"SV_cZsGe9lHlvOBspw","Element":"SQ","PrimaryAttribute":"QID32","SecondaryAttribute":"Hint: Fake images often have functional errors. Image generators do not have a structural underst...","TertiaryAttribute":null,"Payload":{"QuestionText":"<strong>Hint<\/strong>: Fake images often have<strong> functional errors<\/strong>. Image generators do not have a structural understanding of how objects in the world work and interact with each other. This can cause composition errors, dysfunctional objects, and atypical designs. Looking closely may also reveal distorted and unresolved details or incomprehensible text and logos.&nbsp;<br>\n<br>\nIn the image below, the <strong>saucer seems to be floating<\/strong> underneath the cup on the left with no hand holding it.","DefaultChoices":false,"DataExportTag":"visual_tip_3","QuestionType":"DB","Selector":"GRB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Hint: Fake images often have functional errors. Image generators do not have a structural underst...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID32","SubSelector":"WTXB","Graphics":"IM_wTIfIyfXDshncoI","GraphicsDescription":"friends_drinking_coffee.jpg","QuestionJS":"Qualtrics.SurveyEngine.addOnload(function()\n{\n\t\/*Place your JavaScript here to run when the page loads*\/\n\tvar start = Date.now();\n\t\n\tQualtrics.SurveyEngine.addOnPageSubmit(function() {\n\t\tQualtrics.SurveyEngine.setEmbeddedData('visual_tip_3_page_submit',Date.now()-start);\n\t});\n\n});\n\nQualtrics.SurveyEngine.addOnReady(function()\n{\n\t\/*Place your JavaScript here to run when the page is fully displayed*\/\n\tthis.hideNextButton();\n\tsetTimeout(function() { jQuery(\"#NextButton\").show(); },5000);\n\n});\n\nQualtrics.SurveyEngine.addOnUnload(function()\n{\n\t\/*Place your JavaScript here to run when the page is unloaded*\/\n\n});"}},{"SurveyID":"SV_cZsGe9lHlvOBspw","Element":"SQ","PrimaryAttribute":"QID33","SecondaryAttribute":"Hint: Fake images images often look a bit too perfect. People may have glossy, shiny skin, windsw...","TertiaryAttribute":null,"Payload":{"QuestionText":"<strong>Hint<\/strong>:  Fake images images often look a bit<strong> too perfect<\/strong>. People may have glossy, shiny skin, windswept hair, and they may look like a photo in a magazine or a scene from a movie. Sometimes, parts of an image have a different level of detail or vibrancy compared to the rest.&nbsp;<br>\n<br>\nIn the image below, you can see that<strong> the face of the woman is not realistic<\/strong>.","DefaultChoices":false,"DataExportTag":"visual_tip_2","QuestionType":"DB","Selector":"GRB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Hint: Fake images images often look a bit too perfect. People may have glossy, shiny skin, windsw...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID33","SubSelector":"WTXB","Graphics":"IM_VJngiNBKQQiDbZZ","GraphicsDescription":"woman_on_street.jpg","QuestionJS":"Qualtrics.SurveyEngine.addOnload(function()\n{\n\t\/*Place your JavaScript here to run when the page loads*\/\n\tvar start = Date.now();\n\t\n\tQualtrics.SurveyEngine.addOnPageSubmit(function() {\n\t\tQualtrics.SurveyEngine.setEmbeddedData('visual_tip_2_page_submit',Date.now()-start);\n\t});\n\n});\n\nQualtrics.SurveyEngine.addOnReady(function()\n{\n\t\/*Place your JavaScript here to run when the page is fully displayed*\/\n\tthis.hideNextButton();\n\tsetTimeout(function() { jQuery(\"#NextButton\").show(); },5000);\n\n});\n\nQualtrics.SurveyEngine.addOnUnload(function()\n{\n\t\/*Place your JavaScript here to run when the page is unloaded*\/\n\n});"}},{"SurveyID":"SV_cZsGe9lHlvOBspw","Element":"SQ","PrimaryAttribute":"QID34","SecondaryAttribute":"Hint: Fake images often have anatomical errors. For example, people often have missing, extra, or...","TertiaryAttribute":null,"Payload":{"QuestionText":"<strong>Hint<\/strong>: Fake images often have <strong>anatomical errors<\/strong>. For example, people often have missing, extra, or merged fingers, nonexistent fingernails, and unlikely hand proportions.<br>\n<br>\nIn the image below, you can see that the <strong>hands are merged together<\/strong>.","DefaultChoices":false,"DataExportTag":"visual_tip_1","QuestionType":"DB","Selector":"GRB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Hint: Fake images often have anatomical errors. For example, people often have missing, extra, or...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID34","SubSelector":"WTXB","Graphics":"IM_3U3z9i3JQO1hvom","GraphicsDescription":"holding_hands_at_dinner.jpg","QuestionJS":"Qualtrics.SurveyEngine.addOnload(function()\n{\n\t\/*Place your JavaScript here to run when the page loads*\/\n\tvar start = Date.now();\n\t\n\tQualtrics.SurveyEngine.addOnPageSubmit(function() {\n\t\tQualtrics.SurveyEngine.setEmbeddedData('visual_tip_1_page_submit',Date.now()-start);\n\t});\n\n});\n\nQualtrics.SurveyEngine.addOnReady(function()\n{\n\t\/*Place your JavaScript here to run when the page is fully displayed*\/\n\tthis.hideNextButton();\n\tsetTimeout(function() { jQuery(\"#NextButton\").show(); },5000);\n\n});\n\nQualtrics.SurveyEngine.addOnUnload(function()\n{\n\t\/*Place your JavaScript here to run when the page is unloaded*\/\n\n});"}},{"SurveyID":"SV_cZsGe9lHlvOBspw","Element":"SQ","PrimaryAttribute":"QID35","SecondaryAttribute":"Is this image real or fake?*","TertiaryAttribute":null,"Payload":{"QuestionText":"Is this image <strong>real <\/strong>or <strong>fake<\/strong>?<span style=\"color:#FF0000;\">*<\/span>","DefaultChoices":false,"DataExportTag":"task_real_or_fake","QuestionID":"QID35","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Is this image real or fake?*","Choices":{"1":{"Display":"Definitely real"},"2":{"Display":"Probably real"},"3":{"Display":"Probably fake"},"4":{"Display":"Definitely fake"}},"ChoiceOrder":[1,2,3,4],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":5,"NextAnswerId":5}},{"SurveyID":"SV_cZsGe9lHlvOBspw","Element":"SQ","PrimaryAttribute":"QID36","SecondaryAttribute":" ","TertiaryAttribute":null,"Payload":{"QuestionText":"<img alt=\"Image\" src=\"${lm:\/\/Field\/1}\" \/>","DefaultChoices":false,"DataExportTag":"task_image","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":" ","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID36","QuestionJS":"Qualtrics.SurveyEngine.addOnload(function()\n{\n\t\/*Place your JavaScript here to run when the page loads*\/\n\t\/\/ Retrieve the image URL from the Loop & Merge field (piped text)\n    var imageUrl = \"${lm:\/\/Field\/1}\";\n\n    \/\/ Create a new Image object to preload the image\n    var img = new Image();\n\n    \/\/ Set the source to the image URL\n    img.src = imageUrl;\n});\n\nQualtrics.SurveyEngine.addOnReady(function()\n{\n\t\/*Place your JavaScript here to run when the page is fully displayed*\/\n\n});\n\nQualtrics.SurveyEngine.addOnUnload(function()\n{\n\t\/*Place your JavaScript here to run when the page is unloaded*\/\n\n});"}},{"SurveyID":"SV_cZsGe9lHlvOBspw","Element":"SQ","PrimaryAttribute":"QID37","SecondaryAttribute":"(Optional) Seen the image before or trouble loading the image? Please select the option below.","TertiaryAttribute":null,"Payload":{"QuestionText":"<strong>(Optional)<\/strong> Seen the image before or trouble loading the image? Please select the option below.","DefaultChoices":false,"DataExportTag":"task_seen_before","QuestionType":"MC","Selector":"MAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"(Optional) Seen the image before or trouble loading the image? Please select the option below.","Choices":{"1":{"Display":"Yes, I have <strong>seen<\/strong> this image before."},"3":{"Display":"Yes, I experience an <strong>issue<\/strong> and could <strong>NOT <\/strong>see the image."},"4":{"Display":"No, everything was in order and the image was new to me."}},"ChoiceOrder":[1,"3","4"],"Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":5,"NextAnswerId":1,"QuestionID":"QID37"}},{"SurveyID":"SV_cZsGe9lHlvOBspw","Element":"SQ","PrimaryAttribute":"QID38","SecondaryAttribute":"Click to write the question text","TertiaryAttribute":null,"Payload":{"QuestionText":"Click to write the question text","DefaultChoices":false,"DataExportTag":"Q37","QuestionType":"SS","Selector":"TA","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Click to write the question text","Validation":{"Settings":{"ForceResponse":"OFF"}},"GradingData":[],"Language":[],"NextChoiceId":12,"NextAnswerId":1,"Category":"Gauges","Scale":"Smile","Choices":[{"Display":"0"},{"Display":"1"},{"Display":2},{"Display":3},{"Display":4},{"Display":5},{"Display":6},{"Display":7},{"Display":8},{"Display":9},{"Display":10}],"QuestionID":"QID38"}},{"SurveyID":"SV_cZsGe9lHlvOBspw","Element":"SQ","PrimaryAttribute":"QID39","SecondaryAttribute":"Hint:\u00a0Fake images often have functional errors. Image generators do not have a structural underst..","TertiaryAttribute":null,"Payload":{"QuestionText":"<strong>Hint<\/strong>:&nbsp;Fake images often have<strong> functional errors<\/strong>. Image generators do not have a structural understanding of how objects in the world work and interact with each other. This can cause composition errors, dysfunctional objects, and atypical designs. Looking closely may also reveal distorted and unresolved details or incomprehensible text and logos.&nbsp;<br>\n<br>\nCan you spot the error in the image? <strong>Click on it to earn points<\/strong>!","DefaultChoices":false,"DataExportTag":"game_tip_3","QuestionID":"QID39","QuestionType":"DB","Selector":"GRB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Hint:\u00a0Fake images often have functional errors. Image generators do not have a structural underst...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"SubSelector":"WTXB","Graphics":"IM_wTIfIyfXDshncoI","GraphicsDescription":"friends_drinking_coffee.jpg","QuestionJS":"Qualtrics.SurveyEngine.addOnload(function() {\n    console.log(\"Qualtrics onload function started\");\n\n    var that = this;\n    var container = this.getQuestionContainer();\n    var pageStartTime = Date.now(); \/\/ Start timing for the entire page\n    var gameStartTime; \/\/ Will be set when the game initializes\n    \n    function initializeGame() {\n        console.log(\"Initializing game\");\n        gameStartTime = Date.now(); \/\/ Start timing for this specific game\n        \n        \/\/ Find the existing image\n        var existingImage = container.querySelector('img');\n        if (!existingImage) {\n            console.error(\"No image found in the question\");\n            return;\n        }\n        console.log(\"Found image:\", existingImage);\n        \n        \/\/ Create game elements\n        var gameElements = document.createElement('div');\n        gameElements.innerHTML = `\n            <div id=\"gameControls\" style=\"margin-bottom: 15px; display: flex; justify-content: center; align-items: center;\">\n                <div style=\"display: flex; gap: 20px;\">\n                    <div>Total Score: <span id=\"score\">0<\/span><\/div>\n                    <div id=\"timerContainer\">Time left: <span id=\"time\">30<\/span> <span id=\"secondsText\">seconds<\/span><\/div>\n                <\/div>\n            <\/div>\n            <div id=\"message\" style=\"margin-top: 15px; text-align: center; min-height: 20px;\"><\/div>\n        `;\n        \n        \/\/ Insert game elements before the image\n        existingImage.parentNode.insertBefore(gameElements, existingImage);\n        \n        \/\/ Create a container for the image and error region\n        var imageContainer = document.createElement('div');\n        imageContainer.style.position = 'relative';\n        imageContainer.style.display = 'inline-block';\n        existingImage.parentNode.insertBefore(imageContainer, existingImage);\n        imageContainer.appendChild(existingImage);\n        \n        \/\/ Create the error region circle\n        var errorRegionCircle = document.createElement('div');\n        errorRegionCircle.style.position = 'absolute';\n        errorRegionCircle.style.border = '2px solid red';\n        errorRegionCircle.style.borderRadius = '50%';\n        errorRegionCircle.style.pointerEvents = 'none'; \/\/ Ensure clicks pass through to the image\n        errorRegionCircle.style.display = 'none'; \/\/ Initially hidden\n        imageContainer.appendChild(errorRegionCircle);\n        \n        \/\/ Initialize game variables\n        var score = parseInt(Qualtrics.SurveyEngine.getEmbeddedData('totalScore')) || 0;\n        var timeLeft = 30;\n        var gameEnded = false;\n        \n        \/\/ Update score display\n        document.getElementById('score').textContent = score;\n        \n        \/\/ Define the error region as percentages of image dimensions\n        var errorRegion = {xPercent: 0.43, yPercent: 0.6, radiusPercent: 0.0675};\n        \n        \/\/ Function to update error region based on current image size\n        function updateErrorRegion() {\n            var imgRect = existingImage.getBoundingClientRect();\n            errorRegion.x = imgRect.width * errorRegion.xPercent;\n            errorRegion.y = imgRect.height * errorRegion.yPercent;\n            errorRegion.radius = Math.min(imgRect.width, imgRect.height) * errorRegion.radiusPercent;\n            updateErrorRegionCircle();\n        }\n        \n        \/\/ Update error region circle\n        function updateErrorRegionCircle() {\n            errorRegionCircle.style.left = (errorRegion.x - errorRegion.radius) + 'px';\n            errorRegionCircle.style.top = (errorRegion.y - errorRegion.radius) + 'px';\n            errorRegionCircle.style.width = (errorRegion.radius * 2) + 'px';\n            errorRegionCircle.style.height = (errorRegion.radius * 2) + 'px';\n        }\n        \n        \/\/ Initial update of error region\n        updateErrorRegion();\n        \n        \/\/ Add resize event listener to update error region when window size changes\n        window.addEventListener('resize', updateErrorRegion);\n        \n        \/\/ DEBUG: Make error region visible from the start\n        \/\/errorRegionCircle.style.display = 'block';\n        \/\/errorRegionCircle.style.backgroundColor = 'rgba(255, 0, 0, 0.3)';\n        \n        \/\/ Start the timer\n        var timerInterval = setInterval(function() {\n            if (gameEnded) return;\n            timeLeft--;\n            var timerContainer = document.getElementById('timerContainer');\n            var timeElement = document.getElementById('time');\n            timeElement.textContent = timeLeft;\n            if (timeLeft <= 0) {\n                timerContainer.style.color = 'red';\n                endGame(\"Time's up!\", false);\n            }\n        }, 1000);\n        \n        \/\/ Handle image click\n        function handleImageClick(e) {\n            if (gameEnded) return;\n            console.log(\"Image clicked\");\n            var rect = e.target.getBoundingClientRect();\n            var x = e.clientX - rect.left;\n            var y = e.clientY - rect.top;\n            console.log(\"Click coordinates:\", x, y);\n            \n            if (isInErrorRegion(x, y)) {\n                score += 10;\n                document.getElementById('score').textContent = score;\n\t\t\t\tQualtrics.SurveyEngine.setEmbeddedData('game_tip_3_score', 10);\n                endGame(\"<strong>Correct! You found the error. You earned 10 points!<\/strong>\", true);\n            } else {\n                console.log(\"Click was not in the error region\");\n                showFeedback(\"<strong>Not quite! Try again.<\/strong>\", 'red', true);\n            }\n        }\n        \n        \/\/ Show feedback message\n        function showFeedback(message, color, temporary = false) {\n            var messageElement = document.getElementById('message');\n            messageElement.innerHTML = message;\n            messageElement.style.color = color;\n            if (temporary) {\n                setTimeout(() => {\n                    messageElement.textContent = '';\n                    messageElement.style.color = '';\n                }, 1500); \/\/ Clear the message after 1.5 seconds if it's temporary\n            }\n        }\n        \n        \/\/ Check if click is within error region (circle)\n        function isInErrorRegion(x, y) {\n            var dx = x - errorRegion.x;\n            var dy = y - errorRegion.y;\n            return (dx*dx + dy*dy <= errorRegion.radius*errorRegion.radius);\n        }\n        \n        \/\/ End game function\n        function endGame(message, success) {\n            gameEnded = true;\n            clearInterval(timerInterval);\n            showFeedback(message, success ? 'green' : 'red', false);\n            existingImage.removeEventListener('click', handleImageClick);\n            existingImage.style.cursor = 'default'; \/\/ Change cursor back to default when game ends\n            \n            \/\/ Show the error region circle\n            errorRegionCircle.style.display = 'block';\n            errorRegionCircle.style.backgroundColor = success ? 'rgba(0, 255, 0, 0.3)' : 'rgba(255, 0, 0, 0.3)';\n            \n            \/\/ Save the score to Embedded Data\n            try {\n                Qualtrics.SurveyEngine.setEmbeddedData('totalScore', score);\n                console.log(\"Score saved to embedded data:\", score);\n            } catch (error) {\n                console.error(\"Error saving score to embedded data:\", error);\n            }\n            console.log(\"Game ended:\", message);\n            \n            \/\/ Record the time spent on this game\n            var gameTime = Date.now() - gameStartTime;\n            Qualtrics.SurveyEngine.setEmbeddedData('game_tip_3_gameTime', gameTime);\n            console.log(\"Time spent on this game:\", gameTime, \"ms\");\n\n            var message = \"\";\n\n            if (score <= 10) {\n                 message = \"&#127775; Thanks for participating! Spotting errors in fake images can be challenging. With more exposure, you'll likely get better at it.\";\n            } else if (score <= 30) {\n                  message = \"&#128065;&#65039; Good eye! You've shown a solid ability to spot errors in fake images.\";\n            } else if (score <= 50) {\n                 message = \"&#127942; Impressive results! You've demonstrated a keen ability to spot errors in fake images.\";\n            } else {\n                 message = \"Thank you for participating in our AI image identification survey!\";\n            }\n            Qualtrics.SurveyEngine.setEmbeddedData('feedbackMessage', message);\n            \/\/ Show the Qualtrics Next button\n            showNextButton();\n        }\n        \n        \/\/ Make the image clickable and change cursor to hand\n        existingImage.style.cursor = 'pointer';\n        existingImage.addEventListener('click', handleImageClick);\n\n        \/\/ Function to hide the Qualtrics Next button\n        function hideNextButton() {\n            var nextButton = document.querySelector('#NextButton');\n            if (nextButton) {\n                nextButton.style.display = 'none';\n            }\n        }\n\n        \/\/ Function to show the Qualtrics Next button\n        function showNextButton() {\n            var nextButton = document.querySelector('#NextButton');\n            if (nextButton) {\n                nextButton.style.display = '';\n            }\n        }\n\n        \/\/ Hide the Next button at the start of the game\n        hideNextButton();\n    }\n\n    \/\/ Call initializeGame after a short delay to ensure the DOM is ready\n    setTimeout(initializeGame, 500);\n    \n    \/\/ Add the onPageSubmit event handler\n    Qualtrics.SurveyEngine.addOnPageSubmit(function() {\n        var totalPageTime = Date.now() - pageStartTime;\n        Qualtrics.SurveyEngine.setEmbeddedData('game_tip_3_page_submit', totalPageTime);\n        console.log(\"Total time spent on page:\", totalPageTime, \"ms\");\n    });\n});"}},{"SurveyID":"SV_cZsGe9lHlvOBspw","Element":"SQ","PrimaryAttribute":"QID4","SecondaryAttribute":"Welcome! Thank you for taking the time to participate in our survey.\u00a0Before you begin, it is impo..","TertiaryAttribute":null,"Payload":{"QuestionText":"<div style=\"text-align: center;\"><strong>Welcome!<\/strong><\/div>\n<br \/>\nThank you for taking the time to participate in our survey.&nbsp;Before you begin, it is important that you are informed about the procedure of this research. Please read the following information carefully.\n<ul>\n\t<li>This survey should take approximately <strong>10 minutes<\/strong>&nbsp;to complete.<\/li>\n\t<li>Your responses are completely <strong>confidential <\/strong>and will be anonymized. We do not collect any personally identifiable information unless explicitly stated.<\/li>\n\t<li>Your participation is entirely <strong>voluntary<\/strong>, and you may exit the survey at any time.<\/li>\n\t<li>You can ask any questions that arise before deciding to participate.<\/li>\n\t<li>You are <strong><u>at least 18<\/u><\/strong> years old.<\/li>\n\t<li>You will earn between 0.8 Euro and 1.5 Euro and you won&#39;t receive any compensation if you don&#39;t complete the full questionnaire.<\/li>\n<\/ul>\n&nbsp;\n\n<p><strong>Instructions:<\/strong><\/p>\n\n<ul>\n\t<li>Please answer each question as <strong>honestly <\/strong>and <strong>accurately <\/strong>as possible.<\/li>\n\t<li>If you are unsure about a question, select the option that best reflects your view.<\/li>\n<\/ul>\n&nbsp;\n\n<div>By selecting &quot;I consent to participate&quot;, you consent to the terms and conditions described above.<\/div>","DefaultChoices":false,"DataExportTag":"Opening text","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Welcome! Thank you for taking the time to participate in our survey.\u00a0Before you begin, it is impo...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID4"}},{"SurveyID":"SV_cZsGe9lHlvOBspw","Element":"SQ","PrimaryAttribute":"QID40","SecondaryAttribute":"Hint:\u00a0Fake images can produce subtle artifacts that are inconsistent with the laws of physics. Th..","TertiaryAttribute":null,"Payload":{"QuestionText":"<strong>Hint<\/strong>:&nbsp;Fake images can produce subtle <strong>artifacts that are inconsistent with the laws of physics<\/strong>. These include inaccurate shadows, reflections of alternative realities, and depth and perspective issues.&nbsp;<br>\n<br>\nCan you spot the error in the image? <strong>Click on it to earn points<\/strong>!","DefaultChoices":false,"DataExportTag":"game_tip_4","QuestionType":"DB","Selector":"GRB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Hint:\u00a0Fake images can produce subtle artifacts that are inconsistent with the laws of physics. Th...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID40","SubSelector":"WTXB","Graphics":"IM_s85s22BAa1a9rqS","GraphicsDescription":"man_brushing_teeth.jpg","QuestionJS":"Qualtrics.SurveyEngine.addOnload(function() {\n    console.log(\"Qualtrics onload function started\");\n\n    var that = this;\n    var container = this.getQuestionContainer();\n    var pageStartTime = Date.now(); \/\/ Start timing for the entire page\n    var gameStartTime; \/\/ Will be set when the game initializes\n    \n    function initializeGame() {\n        console.log(\"Initializing game\");\n        gameStartTime = Date.now(); \/\/ Start timing for this specific game\n        \n        \/\/ Find the existing image\n        var existingImage = container.querySelector('img');\n        if (!existingImage) {\n            console.error(\"No image found in the question\");\n            return;\n        }\n        console.log(\"Found image:\", existingImage);\n        \n        \/\/ Create game elements\n        var gameElements = document.createElement('div');\n        gameElements.innerHTML = `\n            <div id=\"gameControls\" style=\"margin-bottom: 15px; display: flex; justify-content: center; align-items: center;\">\n                <div style=\"display: flex; gap: 20px;\">\n                    <div>Total Score: <span id=\"score\">0<\/span><\/div>\n                    <div id=\"timerContainer\">Time left: <span id=\"time\">30<\/span> <span id=\"secondsText\">seconds<\/span><\/div>\n                <\/div>\n            <\/div>\n            <div id=\"message\" style=\"margin-top: 15px; text-align: center; min-height: 20px;\"><\/div>\n        `;\n        \n        \/\/ Insert game elements before the image\n        existingImage.parentNode.insertBefore(gameElements, existingImage);\n        \n        \/\/ Create a container for the image and error region\n        var imageContainer = document.createElement('div');\n        imageContainer.style.position = 'relative';\n        imageContainer.style.display = 'inline-block';\n        existingImage.parentNode.insertBefore(imageContainer, existingImage);\n        imageContainer.appendChild(existingImage);\n        \n        \/\/ Create the error region oval\n        var errorRegionOval = document.createElement('div');\n        errorRegionOval.style.position = 'absolute';\n        errorRegionOval.style.border = '2px solid red';\n        errorRegionOval.style.borderRadius = '50%';\n        errorRegionOval.style.pointerEvents = 'none'; \/\/ Ensure clicks pass through to the image\n        errorRegionOval.style.display = 'none'; \/\/ Initially hidden\n        imageContainer.appendChild(errorRegionOval);\n        \n        \/\/ Initialize game variables\n        var score = parseInt(Qualtrics.SurveyEngine.getEmbeddedData('totalScore')) || 0;\n        var timeLeft = 30;\n        var gameEnded = false;\n        \n        \/\/ Update score display\n        document.getElementById('score').textContent = score;\n        \n        \/\/ Define the error region as percentages of image dimensions\n        var errorRegion = {\n            xPercent: 0,\n            yPercent: 0.09,\n            widthPercent: 0.55,\n            heightPercent: 0.67\n        };\n        \n        \/\/ Function to update error region based on current image size\n        function updateErrorRegion() {\n            var imgRect = existingImage.getBoundingClientRect();\n            errorRegion.x = imgRect.width * errorRegion.xPercent;\n            errorRegion.y = imgRect.height * errorRegion.yPercent;\n            errorRegion.width = imgRect.width * errorRegion.widthPercent;\n            errorRegion.height = imgRect.height * errorRegion.heightPercent;\n            updateErrorRegionOval();\n        }\n        \n        \/\/ Update error region oval\n        function updateErrorRegionOval() {\n            errorRegionOval.style.left = errorRegion.x + 'px';\n            errorRegionOval.style.top = errorRegion.y + 'px';\n            errorRegionOval.style.width = errorRegion.width + 'px';\n            errorRegionOval.style.height = errorRegion.height + 'px';\n        }\n        \n        \/\/ Initial update of error region\n        updateErrorRegion();\n        \n        \/\/ Add resize event listener to update error region when window size changes\n        window.addEventListener('resize', updateErrorRegion);\n        \n        \/\/ DEBUG: Make error region visible from the start\n        \/\/errorRegionOval.style.display = 'block';\n        \/\/errorRegionOval.style.backgroundColor = 'rgba(255, 0, 0, 0.3)';\n        \n        \/\/ Start the timer\n        var timerInterval = setInterval(function() {\n            if (gameEnded) return;\n            timeLeft--;\n            var timerContainer = document.getElementById('timerContainer');\n            var timeElement = document.getElementById('time');\n            timeElement.textContent = timeLeft;\n            if (timeLeft <= 0) {\n                timerContainer.style.color = 'red';\n                endGame(\"Time's up!\", false);\n            }\n        }, 1000);\n        \n        \/\/ Handle image click\n        function handleImageClick(e) {\n            if (gameEnded) return;\n            console.log(\"Image clicked\");\n            var rect = e.target.getBoundingClientRect();\n            var x = e.clientX - rect.left;\n            var y = e.clientY - rect.top;\n            console.log(\"Click coordinates:\", x, y);\n            \n            if (isInErrorRegion(x, y)) {\n                score += 10;\n                document.getElementById('score').textContent = score;\n\t\t\t\tQualtrics.SurveyEngine.setEmbeddedData('game_tip_4_score', 10);\n                endGame(\"<strong>Correct! You found the error. You earned 10 points!<\/strong>\", true);\n            } else {\n                console.log(\"Click was not in the error region\");\n                showFeedback(\"<strong>Not quite! Try again.<\/strong>\", 'red', true);\n            }\n        }\n        \n        \/\/ Show feedback message\n        function showFeedback(message, color, temporary = false) {\n            var messageElement = document.getElementById('message');\n            messageElement.innerHTML = message;\n            messageElement.style.color = color;\n            if (temporary) {\n                setTimeout(() => {\n                    messageElement.textContent = '';\n                    messageElement.style.color = '';\n                }, 1500); \/\/ Clear the message after 1.5 seconds if it's temporary\n            }\n        }\n        \n        \/\/ Check if click is within error region (oval)\n        function isInErrorRegion(x, y) {\n            var centerX = errorRegion.x + errorRegion.width \/ 2;\n            var centerY = errorRegion.y + errorRegion.height \/ 2;\n            var rx = errorRegion.width \/ 2;\n            var ry = errorRegion.height \/ 2;\n            \n            var dx = x - centerX;\n            var dy = y - centerY;\n            \n            return ((dx * dx) \/ (rx * rx) + (dy * dy) \/ (ry * ry) <= 1);\n        }\n        \n        \/\/ End game function\n        function endGame(message, success) {\n            gameEnded = true;\n            clearInterval(timerInterval);\n            showFeedback(message, success ? 'green' : 'red', false);\n            existingImage.removeEventListener('click', handleImageClick);\n            existingImage.style.cursor = 'default'; \/\/ Change cursor back to default when game ends\n            \n            \/\/ Show the error region oval\n            errorRegionOval.style.display = 'block';\n            errorRegionOval.style.backgroundColor = success ? 'rgba(0, 255, 0, 0.3)' : 'rgba(255, 0, 0, 0.3)';\n            \n            \/\/ Save the score to Embedded Data\n            try {\n                Qualtrics.SurveyEngine.setEmbeddedData('totalScore', score);\n                console.log(\"Score saved to embedded data:\", score);\n            } catch (error) {\n                console.error(\"Error saving score to embedded data:\", error);\n            }\n            console.log(\"Game ended:\", message);\n            \n            \/\/ Record the time spent on this game\n            var gameTime = Date.now() - gameStartTime;\n            Qualtrics.SurveyEngine.setEmbeddedData('game_tip_4_gameTime', gameTime);\n            console.log(\"Time spent on this game:\", gameTime, \"ms\");\n            \n            var message = \"\";\n\n            if (score <= 10) {\n                 message = \"&#127775; Thanks for participating! Spotting errors in fake images can be challenging. With more exposure, you'll likely get better at it.\";\n            } else if (score <= 30) {\n                  message = \"&#128065;&#65039; Good eye! You've shown a solid ability to spot errors in fake images.\";\n            } else if (score <= 50) {\n                 message = \"&#127942; Impressive results! You've demonstrated a keen ability to spot errors in fake images.\";\n            } else {\n                 message = \"Thank you for participating in our AI image identification survey!\";\n            }\n\t\t\tQualtrics.SurveyEngine.setEmbeddedData('feedbackMessage', message);\n            \n            \/\/ Show the Qualtrics Next button\n            showNextButton();\n        }\n        \n        \/\/ Make the image clickable and change cursor to hand\n        existingImage.style.cursor = 'pointer';\n        existingImage.addEventListener('click', handleImageClick);\n\n        \/\/ Function to hide the Qualtrics Next button\n        function hideNextButton() {\n            var nextButton = document.querySelector('#NextButton');\n            if (nextButton) {\n                nextButton.style.display = 'none';\n            }\n        }\n\n        \/\/ Function to show the Qualtrics Next button\n        function showNextButton() {\n            var nextButton = document.querySelector('#NextButton');\n            if (nextButton) {\n                nextButton.style.display = '';\n            }\n        }\n\n        \/\/ Hide the Next button at the start of the game\n        hideNextButton();\n    }\n\n    \/\/ Call initializeGame after a short delay to ensure the DOM is ready\n    setTimeout(initializeGame, 500);\n    \n    \/\/ Add the onPageSubmit event handler\n    Qualtrics.SurveyEngine.addOnPageSubmit(function() {\n        var totalPageTime = Date.now() - pageStartTime;\n        Qualtrics.SurveyEngine.setEmbeddedData('game_tip_4_page_submit', totalPageTime);\n        console.log(\"Total time spent on page:\", totalPageTime, \"ms\");\n    });\n});"}},{"SurveyID":"SV_cZsGe9lHlvOBspw","Element":"SQ","PrimaryAttribute":"QID41","SecondaryAttribute":"Hint:\u00a0Fake images may have sociocultural errors. For example, the images may show scenarios that...","TertiaryAttribute":null,"Payload":{"QuestionText":"<strong>Hint<\/strong>:&nbsp;Fake images may have <strong>sociocultural errors<\/strong>. For example, the images may show scenarios that are inappropriate, unlikely to be seen in the real world, violate subtle rules specific to different cultures, or are historically inaccurate.&nbsp;<br>\n<br>\nCan you spot the error in the image? <strong>Click on it to earn points<\/strong>!","DefaultChoices":false,"DataExportTag":"game_tip_5","QuestionType":"DB","Selector":"GRB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Hint:\u00a0Fake images may have sociocultural errors. For example, the images may show scenarios that...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID41","SubSelector":"WTXB","Graphics":"IM_B6bCU8LQeSMFL5L","GraphicsDescription":"pope-wearing-balenciaga-jacket.jpg","QuestionJS":"Qualtrics.SurveyEngine.addOnload(function() {\n    console.log(\"Qualtrics onload function started\");\n\n    var that = this;\n    var container = this.getQuestionContainer();\n    var pageStartTime = Date.now(); \/\/ Start timing for the entire page\n    var gameStartTime; \/\/ Will be set when the game initializes\n    \n    function initializeGame() {\n        console.log(\"Initializing game\");\n        gameStartTime = Date.now(); \/\/ Start timing for this specific game\n        \n        \/\/ Find the existing image\n        var existingImage = container.querySelector('img');\n        if (!existingImage) {\n            console.error(\"No image found in the question\");\n            return;\n        }\n        console.log(\"Found image:\", existingImage);\n        \n        \/\/ Create game elements\n        var gameElements = document.createElement('div');\n        gameElements.innerHTML = `\n            <div id=\"gameControls\" style=\"margin-bottom: 15px; display: flex; justify-content: center; align-items: center;\">\n                <div style=\"display: flex; gap: 20px;\">\n                    <div>Total Score: <span id=\"score\">0<\/span><\/div>\n                    <div id=\"timerContainer\">Time left: <span id=\"time\">30<\/span> <span id=\"secondsText\">seconds<\/span><\/div>\n                <\/div>\n            <\/div>\n            <div id=\"message\" style=\"margin-top: 15px; text-align: center; min-height: 20px;\"><\/div>\n        `;\n        \n        \/\/ Insert game elements before the image\n        existingImage.parentNode.insertBefore(gameElements, existingImage);\n        \n        \/\/ Create a container for the image and error region\n        var imageContainer = document.createElement('div');\n        imageContainer.style.position = 'relative';\n        imageContainer.style.display = 'inline-block';\n        existingImage.parentNode.insertBefore(imageContainer, existingImage);\n        imageContainer.appendChild(existingImage);\n        \n        \/\/ Create the error region oval\n        var errorRegionOval = document.createElement('div');\n        errorRegionOval.style.position = 'absolute';\n        errorRegionOval.style.border = '2px solid red';\n        errorRegionOval.style.borderRadius = '50%';\n        errorRegionOval.style.pointerEvents = 'none'; \/\/ Ensure clicks pass through to the image\n        errorRegionOval.style.display = 'none'; \/\/ Initially hidden\n        imageContainer.appendChild(errorRegionOval);\n        \n        \/\/ Initialize game variables\n        var score = parseInt(Qualtrics.SurveyEngine.getEmbeddedData('totalScore')) || 0;\n        var timeLeft = 30;\n        var gameEnded = false;\n        \n        \/\/ Update score display\n        document.getElementById('score').textContent = score;\n        \n        \/\/ Define the error region as percentages of image dimensions\n        var errorRegion = {\n            xPercent: 0.033,\n            yPercent: 0.075,\n            widthPercent: 0.8,\n            heightPercent: 0.95\n        };\n        \n        \/\/ Function to update error region based on current image size\n        function updateErrorRegion() {\n            var imgRect = existingImage.getBoundingClientRect();\n            errorRegion.x = imgRect.width * errorRegion.xPercent;\n            errorRegion.y = imgRect.height * errorRegion.yPercent;\n            errorRegion.width = imgRect.width * errorRegion.widthPercent;\n            errorRegion.height = imgRect.height * errorRegion.heightPercent;\n            updateErrorRegionOval();\n        }\n        \n        \/\/ Update error region oval\n        function updateErrorRegionOval() {\n            errorRegionOval.style.left = errorRegion.x + 'px';\n            errorRegionOval.style.top = errorRegion.y + 'px';\n            errorRegionOval.style.width = errorRegion.width + 'px';\n            errorRegionOval.style.height = errorRegion.height + 'px';\n        }\n        \n        \/\/ Initial update of error region\n        updateErrorRegion();\n        \n        \/\/ Add resize event listener to update error region when window size changes\n        window.addEventListener('resize', updateErrorRegion);\n        \n        \/\/ DEBUG: Make error region visible from the start\n        \/\/errorRegionOval.style.display = 'block';\n        \/\/errorRegionOval.style.backgroundColor = 'rgba(255, 0, 0, 0.3)';\n        \n        \/\/ Start the timer\n        var timerInterval = setInterval(function() {\n            if (gameEnded) return;\n            timeLeft--;\n            var timerContainer = document.getElementById('timerContainer');\n            var timeElement = document.getElementById('time');\n            timeElement.textContent = timeLeft;\n            if (timeLeft <= 0) {\n                timerContainer.style.color = 'red';\n                endGame(\"Time's up!\", false);\n            }\n        }, 1000);\n        \n        \/\/ Handle image click\n        function handleImageClick(e) {\n            if (gameEnded) return;\n            console.log(\"Image clicked\");\n            var rect = e.target.getBoundingClientRect();\n            var x = e.clientX - rect.left;\n            var y = e.clientY - rect.top;\n            console.log(\"Click coordinates:\", x, y);\n            \n            if (isInErrorRegion(x, y)) {\n                score += 10;\n                document.getElementById('score').textContent = score;\n\t\t\t\tQualtrics.SurveyEngine.setEmbeddedData('game_tip_5_score', 10);\n                endGame(\"<strong>Correct! You found the error. You earned 10 points!<\/strong>\", true);\n            } else {\n                console.log(\"Click was not in the error region\");\n                showFeedback(\"<strong>Not quite! Try again.<\/strong>\", 'red', true);\n            }\n        }\n        \n        \/\/ Show feedback message\n        function showFeedback(message, color, temporary = false) {\n            var messageElement = document.getElementById('message');\n            messageElement.innerHTML = message;\n            messageElement.style.color = color;\n            if (temporary) {\n                setTimeout(() => {\n                    messageElement.textContent = '';\n                    messageElement.style.color = '';\n                }, 1500); \/\/ Clear the message after 1.5 seconds if it's temporary\n            }\n        }\n        \n        \/\/ Check if click is within error region (oval)\n        function isInErrorRegion(x, y) {\n            var centerX = errorRegion.x + errorRegion.width \/ 2;\n            var centerY = errorRegion.y + errorRegion.height \/ 2;\n            var rx = errorRegion.width \/ 2;\n            var ry = errorRegion.height \/ 2;\n            \n            var dx = x - centerX;\n            var dy = y - centerY;\n            \n            return ((dx * dx) \/ (rx * rx) + (dy * dy) \/ (ry * ry) <= 1);\n        }\n        \n        \/\/ End game function\n        function endGame(message, success) {\n            gameEnded = true;\n            clearInterval(timerInterval);\n            showFeedback(message, success ? 'green' : 'red', false);\n            existingImage.removeEventListener('click', handleImageClick);\n            existingImage.style.cursor = 'default'; \/\/ Change cursor back to default when game ends\n            \n            \/\/ Show the error region oval\n            errorRegionOval.style.display = 'block';\n            errorRegionOval.style.backgroundColor = success ? 'rgba(0, 255, 0, 0.3)' : 'rgba(255, 0, 0, 0.3)';\n            \n            \/\/ Save the score to Embedded Data\n            try {\n                Qualtrics.SurveyEngine.setEmbeddedData('totalScore', score);\n                console.log(\"Score saved to embedded data:\", score);\n            } catch (error) {\n                console.error(\"Error saving score to embedded data:\", error);\n            }\n            console.log(\"Game ended:\", message);\n            \n            \/\/ Record the time spent on this game\n            var gameTime = Date.now() - gameStartTime;\n            Qualtrics.SurveyEngine.setEmbeddedData('game_tip_5_gameTime', gameTime);\n            console.log(\"Time spent on this game:\", gameTime, \"ms\");\n\n            var message = \"\";\n\n            if (score <= 10) {\n                 message = \"&#127775; Thanks for participating! Spotting errors in fake images can be challenging. With more exposure, you'll likely get better at it.\";\n            } else if (score <= 30) {\n                  message = \"&#128065;&#65039; Good eye! You've shown a solid ability to spot errors in fake images.\";\n            } else if (score <= 50) {\n                 message = \"&#127942; Impressive results! You've demonstrated a keen ability to spot errors in fake images.\";\n            } else {\n                 message = \"Thank you for participating in our AI image identification survey!\";\n            }\n\n            Qualtrics.SurveyEngine.setEmbeddedData('feedbackMessage', message);\n            \/\/ Show the Qualtrics Next button\n            showNextButton();\n        }\n        \n        \/\/ Make the image clickable and change cursor to hand\n        existingImage.style.cursor = 'pointer';\n        existingImage.addEventListener('click', handleImageClick);\n\n        \/\/ Function to hide the Qualtrics Next button\n        function hideNextButton() {\n            var nextButton = document.querySelector('#NextButton');\n            if (nextButton) {\n                nextButton.style.display = 'none';\n            }\n        }\n\n        \/\/ Function to show the Qualtrics Next button\n        function showNextButton() {\n            var nextButton = document.querySelector('#NextButton');\n            if (nextButton) {\n                nextButton.style.display = '';\n            }\n        }\n\n        \/\/ Hide the Next button at the start of the game\n        hideNextButton();\n    }\n\n    \/\/ Call initializeGame after a short delay to ensure the DOM is ready\n    setTimeout(initializeGame, 500);\n    \n    \/\/ Add the onPageSubmit event handler\n    Qualtrics.SurveyEngine.addOnPageSubmit(function() {\n        var totalPageTime = Date.now() - pageStartTime;\n        Qualtrics.SurveyEngine.setEmbeddedData('game_tip_5_page_submit', totalPageTime);\n        console.log(\"Total time spent on page:\", totalPageTime, \"ms\");\n    });\n});"}},{"SurveyID":"SV_cZsGe9lHlvOBspw","Element":"SQ","PrimaryAttribute":"QID42","SecondaryAttribute":"Would you share this image on your social media?*","TertiaryAttribute":null,"Payload":{"QuestionText":"Would you <strong>share <\/strong>this image on your social media?<span style=\"color:#FF0000;\">*<\/span>","DefaultChoices":false,"DataExportTag":"task_sharing","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","LabelPosition":"SIDE"},"QuestionDescription":"Would you share this image on your social media?*","Choices":{"1":{"Display":"Yes"},"2":{"Display":"No"},"4":{"Display":"Don't know"}},"ChoiceOrder":["1","2","4"],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":6,"NextAnswerId":1,"QuestionID":"QID42","AnalyzeChoices":{"2":"on"},"Randomization":{"Advanced":null,"ConsistentScaleReversal":true,"TotalRandSubset":"","Type":"None"},"QuestionJS":"Qualtrics.SurveyEngine.addOnload(function()\n{\n\n});\n\nQualtrics.SurveyEngine.addOnReady(function()\n{\n\t\/*Place your JavaScript here to run when the page is fully displayed*\/\n\n});\n\nQualtrics.SurveyEngine.addOnUnload(function()\n{\n\t\/*Place your JavaScript here to run when the page is unloaded*\/\n\n});"}},{"SurveyID":"SV_cZsGe9lHlvOBspw","Element":"SQ","PrimaryAttribute":"QID43","SecondaryAttribute":"Image category?","TertiaryAttribute":null,"Payload":{"QuestionText":"Image category?","DefaultChoices":false,"DataExportTag":"image category","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Image category?","Choices":{"1":{"Display":"real"},"2":{"Display":"fake"},"3":{"Display":"viral"}},"ChoiceOrder":["1","2","3"],"Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID43","QuestionJS":"Qualtrics.SurveyEngine.addOnload(function()\n{\n    var category = \"${lm:\/\/Field\/2}\";\n    if(category == \"real\") {\n        this.setSelectedChoices(1);\n    } else if(category == \"fake\") {\n        this.setSelectedChoices(2);\n    } else if(category == \"viral\") {\n        this.setSelectedChoices(3);\n    }\n});\n\nQualtrics.SurveyEngine.addOnReady(function()\n{\n\t\/*Place your JavaScript here to run when the page is fully displayed*\/\n\n});\n\nQualtrics.SurveyEngine.addOnUnload(function()\n{\n\t\/*Place your JavaScript here to run when the page is unloaded*\/\n\n});","DisplayLogic":{"0":{"0":{"Description":"<span class=\"ConjDesc\">If<\/span> <span class=\"LeftOpDesc\">ShowHiddenQuestion<\/span> <span class=\"OpDesc\">Is Equal to<\/span> <span class=\"RightOpDesc\"> 1 <\/span>","LeftOperand":"ShowHiddenQuestion","LogicType":"EmbeddedField","Operator":"EqualTo","RightOperand":"1","Type":"Expression"},"Type":"If"},"Type":"BooleanExpression","inPage":false}}},{"SurveyID":"SV_cZsGe9lHlvOBspw","Element":"SQ","PrimaryAttribute":"QID44","SecondaryAttribute":"How confident are you about your fake image detection choices on a scale of 0-100?*","TertiaryAttribute":null,"Payload":{"QuestionText":"How <strong>confident <\/strong>are you about your fake image detection choices on a scale of 0-100?<span style=\"color:#FF0000;\">*<\/span>","DefaultChoices":false,"DataExportTag":"slider_confidence","QuestionType":"Slider","Selector":"HSLIDER","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","CSSliderMin":0,"CSSliderMax":100,"GridLines":10,"SnapToGrid":false,"NumDecimals":"0","ShowValue":true,"CustomStart":false,"NotApplicable":false,"MobileFirst":true,"SliderStartPositions":{"1":0.5}},"QuestionDescription":"How confident are you about your fake image detection choices on a scale of 0-100?*","Choices":{"1":{"Display":"&nbsp;"}},"ChoiceOrder":[1],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":2,"NextAnswerId":8,"Labels":{"1":{"Display":"Not confident at all"},"2":{"Display":"Very confident"}},"QuestionID":"QID44"}},{"SurveyID":"SV_cZsGe9lHlvOBspw","Element":"SQ","PrimaryAttribute":"QID45","SecondaryAttribute":"The ages of Mark and Adam add up to 28 years total. Mark is 20 years older than Adam. How old is...","TertiaryAttribute":null,"Payload":{"QuestionText":"The ages of Mark and Adam add up to 28 years total. Mark is 20 years older than Adam. How old is Adam?<span style=\"color:#FF0000;\">*<\/span>","DefaultChoices":false,"DataExportTag":"CRT_1","QuestionType":"TE","Selector":"SL","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"The ages of Mark and Adam add up to 28 years total. Mark is 20 years older than Adam. How old is...","Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"ContentType","MinChars":"1","ContentType":"ValidNumber","ValidDateType":"DateWithFormat","ValidPhoneType":"ValidUSPhone","ValidZipType":"ValidUSZip","ValidNumber":{"Min":"0","Max":"","NumDecimals":""}}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"SearchSource":{"AllowFreeResponse":"false"},"QuestionID":"QID45"}},{"SurveyID":"SV_cZsGe9lHlvOBspw","Element":"SQ","PrimaryAttribute":"QID46","SecondaryAttribute":"If it takes 10 seconds for 10 printers to print out 10 pages of paper, how many seconds will it t...","TertiaryAttribute":null,"Payload":{"QuestionText":"If it takes 10 seconds for 10 printers to print out 10 pages of paper, how many seconds will it take 50 printers to print out 50 pages of paper?<span style=\"color:#FF0000;\">*<\/span>","DefaultChoices":false,"DataExportTag":"CRT_2","QuestionType":"TE","Selector":"SL","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"If it takes 10 seconds for 10 printers to print out 10 pages of paper, how many seconds will it t...","Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"ContentType","MinChars":"1","ContentType":"ValidNumber","ValidDateType":"DateWithFormat","ValidPhoneType":"ValidUSPhone","ValidZipType":"ValidUSZip","ValidNumber":{"Min":"0","Max":"","NumDecimals":""}}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"SearchSource":{"AllowFreeResponse":"false"},"QuestionID":"QID46"}},{"SurveyID":"SV_cZsGe9lHlvOBspw","Element":"SQ","PrimaryAttribute":"QID47","SecondaryAttribute":"On a loaf of bread, there is a patch of mold. Every day, the patch doubles in size. If it takes 4...","TertiaryAttribute":null,"Payload":{"QuestionText":"On a loaf of bread, there is a patch of mold. Every day, the patch doubles in size. If it takes 40 days for the patch to cover the entire loaf of bread, how many days would it take for the patch to cover half of the loaf of bread?<span style=\"color:#FF0000;\">*<\/span>","DefaultChoices":false,"DataExportTag":"CRT_3","QuestionType":"TE","Selector":"SL","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"On a loaf of bread, there is a patch of mold. Every day, the patch doubles in size. If it takes 4...","Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"ContentType","MinChars":"1","ContentType":"ValidNumber","ValidDateType":"DateWithFormat","ValidPhoneType":"ValidUSPhone","ValidZipType":"ValidUSZip","ValidNumber":{"Min":"","Max":"","NumDecimals":""}}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"SearchSource":{"AllowFreeResponse":"false"},"QuestionID":"QID47"}},{"SurveyID":"SV_cZsGe9lHlvOBspw","Element":"SQ","PrimaryAttribute":"QID48","SecondaryAttribute":"Additional questions \u00a0 In the following section, we will ask you some additional questions about...","TertiaryAttribute":null,"Payload":{"QuestionText":"<div style=\"text-align: center;\"><strong>Additional questions<\/strong><br>\n&nbsp;<\/div>\n\n<div style=\"text-align: left;\">In the following section, we will ask you some additional questions about your social media use, your knowledge about AI and some general knowledge questions.<\/div>","DefaultChoices":false,"DataExportTag":"additional_Q_text","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Additional questions \u00a0 In the following section, we will ask you some additional questions about...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID48"}},{"SurveyID":"SV_cZsGe9lHlvOBspw","Element":"SQ","PrimaryAttribute":"QID49","SecondaryAttribute":"Which social media platforms do you use (if any)?*","TertiaryAttribute":null,"Payload":{"QuestionText":"Which <strong>social media platforms<\/strong> do you use (if any)?<span style=\"color:#FF0000;\">*<\/span>","DefaultChoices":false,"DataExportTag":"platform_presence","QuestionType":"MC","Selector":"MAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Which social media platforms do you use (if any)?*","Choices":{"1":{"Display":"Facebook"},"2":{"Display":"Twitter\/X"},"3":{"Display":"Snapchat"},"4":{"Display":"Instagram"},"5":{"Display":"WhatsApp"},"6":{"Display":"TikTok"},"7":{"Display":"Other, namely","TextEntry":"true"},"8":{"Display":"None"}},"ChoiceOrder":[1,2,3,4,5,6,7,8],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":9,"NextAnswerId":1,"QuestionID":"QID49","Randomization":{"Advanced":{"FixedOrder":["{~Randomized~}","{~Randomized~}","{~Randomized~}","{~Randomized~}","{~Randomized~}","{~Randomized~}","7","8"],"RandomSubSet":[],"RandomizeAll":["1","2","3","4","5","6"],"ScaleReversal":[],"TotalRandSubset":0,"Undisplayed":[]},"ConsistentScaleReversal":false,"EvenPresentation":false,"TotalRandSubset":"","Type":"Advanced"}}},{"SurveyID":"SV_cZsGe9lHlvOBspw","Element":"SQ","PrimaryAttribute":"QID5","SecondaryAttribute":"PARTICIPANT CONSENT FORM \u00a0\u00a0 Thank you for participating in this study. To be eligible to particip.","TertiaryAttribute":null,"Payload":{"QuestionText":"<div style=\"text-align: center;\"><strong>PARTICIPANT CONSENT FORM<\/strong><br>\n&nbsp;&nbsp;<\/div>\n\n<div style=\"text-align: left;\">Thank you for participating in this study.<br>\n<br>\nTo be eligible to participate, you must be <strong>18 years of age or older.<\/strong><\/div>\n\n<div style=\"text-align: left;\">&nbsp;<\/div>\n\n<div style=\"text-align: left;\"><strong>PURPOSE AND PROCEDURE:<\/strong>&nbsp;We are interested in the effects\nof different learning methods on your opinions about\nvarious images. You will be presented with multiple images. Your task will be to rate whether you think the images are real and whether you would consider sharing them on social media. At the end of the study, all participants will be asked some additional questions. The expected time to complete the study is around <strong>5 minutes<\/strong>. After successful completion, you will be provided with compensation as a thank-you for your time.&nbsp;<\/div>\n&nbsp;<br>\n<strong>CONFIDENTIALITY<\/strong>:&nbsp;Your responses are completely <strong>confidential <\/strong>and will be <strong>anonymized<\/strong>. We do not collect any personally identifiable information unless explicitly stated.&nbsp;<br>\n<br>\n<strong>STORAGE OF DATA:<\/strong>&nbsp;Original electronic data will be stored securely with password protection. Only the primary researchers will have access to the original electronic data. Upon submission of manuscripts associated with this research,<strong> anonymized data will be made available to other researchers.<\/strong>&nbsp;Data will be used for&nbsp;<b data-stringify-type=\"bold\">scientific purposes&nbsp;<\/b>only.<br>\n<br>\n<strong>RIGHT TO WITHDRAW:<\/strong>&nbsp;Participation is entirely <strong>voluntary<\/strong>. If you decide to participate you are free to discontinue participation at any time without question or penalty during the survey. Participants cannot withdraw after they have submitted their responses. Information collected from you cannot be discarded; however, because your responses are anonymous, they will be not tied to you in any way.&nbsp;<br>\n<br>\n<strong>QUESTIONS OR CONCERNS:<\/strong>&nbsp;If you have any questions, please feel free to contact a member of the research team using the provided contact information.<br>\n<br>\n<strong>PRIMARY RESEARCHERS:<\/strong><br>\n<br>\nDominique Geissler<br>\nStefan Feuerriegel<br>\n<br>\nInstitute of AI in Management, School of Management, LMU Munich<br>\n<strong>Contact<\/strong>: d.geissler@lmu.de\n\n<ul>\n<\/ul>\n&nbsp;\n\n<div>By selecting \"I consent to participate\", you consent to the terms and conditions described above.<span style=\"color:#FF0000;\">*<\/span><\/div>","DefaultChoices":false,"DataExportTag":"Consent","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","LabelPosition":"SIDE"},"QuestionDescription":"PARTICIPANT CONSENT FORM \u00a0\u00a0 Thank you for participating in this study. To be eligible to particip...","Choices":{"1":{"Display":"I <strong>consent <\/strong>to participate."},"2":{"Display":"I do <strong>NOT <\/strong>consent to participate."}},"ChoiceOrder":[1,2],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":3,"NextAnswerId":1,"QuestionID":"QID5"}},{"SurveyID":"SV_cZsGe9lHlvOBspw","Element":"SQ","PrimaryAttribute":"QID50","SecondaryAttribute":"Which type of content would you consider sharing on social media (if any)?*","TertiaryAttribute":null,"Payload":{"QuestionText":"Which type of content would you consider<strong> sharing on social media<\/strong> (if any)?<span style=\"color:#FF0000;\">*<\/span>","DefaultChoices":false,"DataExportTag":"content_sharing","QuestionType":"MC","Selector":"MAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Which type of content would you consider sharing on social media (if any)?*","Choices":{"1":{"Display":"Political news"},"2":{"Display":"Sports news"},"3":{"Display":"Celebrity news"},"4":{"Display":"Science\/technology news"},"5":{"Display":"Business news"},"6":{"Display":"Other, namely","TextEntry":"true"},"7":{"Display":"None"},"8":{