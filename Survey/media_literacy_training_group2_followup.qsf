bute":"Timing","TertiaryAttribute":null,"Payload":{"QuestionText":"Timing","DefaultChoices":false,"QuestionType":"Timing","Selector":"PageTimer","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","MinSeconds":2,"MaxSeconds":"0"},"QuestionDescription":"Timing","Choices":{"1":{"Display":"First Click"},"2":{"Display":"Last Click"},"3":{"Display":"Page Submit"},"4":{"Display":"Click Count"}},"GradingData":[],"Language":[],"NextChoiceId":32,"NextAnswerId":1,"QuestionText_Unsafe":"Timing","DataExportTag":"Q117","QuestionID":"QID117"}},{"SurveyID":"SV_cZsGe9lHlvOBspw","Element":"SQ","PrimaryAttribute":"QID118","SecondaryAttribute":" ","TertiaryAttribute":null,"Payload":{"QuestionText":"<img src=\"${lm:\/\/Field\/1}\" alt=\"Image\">","DefaultChoices":false,"QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":" ","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionJS":"Qualtrics.SurveyEngine.addOnload(function()\n{\n\t\/*Place your JavaScript here to run when the page loads*\/\n\t\/\/ Retrieve the image URL from the Loop & Merge field (piped text)\n    var imageUrl = \"${lm:\/\/Field\/1}\";\n\n    \/\/ Create a new Image object to preload the image\n    var img = new Image();\n\n    \/\/ Set the source to the image URL\n    img.src = imageUrl;\n\n});\n\nQualtrics.SurveyEngine.addOnReady(function()\n{\n\t\/*Place your JavaScript here to run when the page is fully displayed*\/\n\n});\n\nQualtrics.SurveyEngine.addOnUnload(function()\n{\n\t\/*Place your JavaScript here to run when the page is unloaded*\/\n\n});","QuestionText_Unsafe":"<img src=\"${lm:\/\/Field\/1}\" alt=\"Image\">","DataExportTag":"image_1_fake","QuestionID":"QID118"}},{"SurveyID":"SV_cZsGe9lHlvOBspw","Element":"SQ","PrimaryAttribute":"QID119","SecondaryAttribute":"Is this image real or fake?*","TertiaryAttribute":null,"Payload":{"QuestionText":"Is this image <strong>real <\/strong>or <strong>fake<\/strong>?<span style=\"color:#FF0000;\">*<\/span>","DefaultChoices":false,"QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Is this image real or fake?*","Choices":{"1":{"Display":"Definitely real"},"2":{"Display":"Probably real"},"3":{"Display":"Probably fake"},"4":{"Display":"Definitely fake"}},"ChoiceOrder":[1,2,3,4],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":5,"NextAnswerId":5,"QuestionText_Unsafe":"Is this image <strong>real <\/strong>or <strong>fake<\/strong>?","DataExportTag":"Q119","QuestionID":"QID119"}},{"SurveyID":"SV_cZsGe9lHlvOBspw","Element":"SQ","PrimaryAttribute":"QID12","SecondaryAttribute":"AI-image generation Some of the images you see online could be generated by artificial intelligen...","TertiaryAttribute":null,"Payload":{"QuestionText":"<div style=\"text-align: center;\"><strong>AI-image generation<\/strong><\/div>\n\n<div style=\"text-align: left;\"><br>\nSome of the images you see online could be generated by artificial intelligence (AI) and are hence <strong>fake<\/strong>. Here, we want to teach you <strong>how AI generates fake images.<\/strong>&nbsp;Later, we will ask you to apply your knowledge in a <strong>fake image detection task<\/strong>.<br>\n<br>\nPlease<strong> READ THE FOLLOWING PARAGRAPH CAREFULLY<\/strong>:&nbsp;&nbsp;<br>\n&nbsp;<\/div>\n\n<div style=\"text-align: left;\">AI can learn how to generate realistic images by looking at millions of example pictures. After inputting the example images into the AI, they are transformed into representations that only computers can understand and that don\u2019t mean anything to humans. From those, AI then learns patterns of how the world, such as objects, people, and places look like. After training, humans can ask AI models to generate images through simple input text, this is called prompting. The possibilities of AI-generated images are endless. For example, AI can generate things that have never been seen before such as made-up scenarios or even attempt to imitate real people or places.<span style=\"color:#FF0000;\">*<\/span><\/div>","DefaultChoices":false,"DataExportTag":"Explanation","QuestionID":"QID12","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"AI-image generation Some of the images you see online could be generated by artificial intelligen...","Choices":{"1":{"Display":"I read the above paragraph carefully."}},"ChoiceOrder":[1],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":2,"NextAnswerId":1}},{"SurveyID":"SV_cZsGe9lHlvOBspw","Element":"SQ","PrimaryAttribute":"QID120","SecondaryAttribute":"Would you share this image on your social media?*","TertiaryAttribute":null,"Payload":{"QuestionText":"Would you <strong>share <\/strong>this image on your social media?<span style=\"color:#FF0000;\">*<\/span>","DefaultChoices":false,"QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","LabelPosition":"SIDE"},"QuestionDescription":"Would you share this image on your social media?*","Choices":{"1":{"Display":"Yes"},"2":{"Display":"No"},"3":{"Display":"Don't know"}},"ChoiceOrder":["1","2","3"],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"AnalyzeChoices":{"2":"on"},"Randomization":{"Advanced":null,"ConsistentScaleReversal":true,"TotalRandSubset":"","Type":"None"